#!/usr/bin/env python3
"""ms-semgrep — Architectural Rule Enforcement via Semgrep

Runs custom semgrep rules defined in .semgrep/rules/ against the backend.
Each rule maps to a Core Rule in docs/CORE_RULES.md.

This closes the gap identified in Core Rule 3.6 (overly-narrow patterns):
rules are verified against known instances from the Lessons Learned table
before being declared active. The bug corpus IS the test suite for the rules.

Findings → data/semgrep_findings.json → auto-ingested by ms-audit --improve

Usage:
  ms-semgrep              # run all custom rules
  ms-semgrep --quick      # only ERROR severity
  ms-semgrep --rule RULE  # single rule by id
  ms-semgrep --verify     # verify each rule matches at least one known instance

Install: sudo ln -sf /srv/mediastack/ms-semgrep /usr/local/bin/ms-semgrep
"""
from __future__ import annotations

import json
import subprocess
import sys
import time
from pathlib import Path

# ── Output style — matches ms-update canonical design ─────────────────────
_RESET = "\033[0m"; _BOLD = "\033[1m"; _DIM  = "\033[2m"
_GREEN = "\033[0;32m"; _YELLOW = "\033[1;33m"; _RED = "\033[0;31m"; _CYAN = "\033[0;36m"

def G(s): return f"{_GREEN}{s}{_RESET}"
def R(s): return f"{_RED}{s}{_RESET}"
def Y(s): return f"{_YELLOW}{s}{_RESET}"
def D(s): return f"{_DIM}{s}{_RESET}"
def B(s): return f"{_BOLD}{s}{_RESET}"
def C(s): return f"{_CYAN}{s}{_RESET}"

def ok(msg):   print(f"  {G('✓')} {msg}")
def fail(msg): print(f"  {R('✗')} {msg}")
def warn(msg): print(f"  {Y('!')} {msg}")
def info(msg): print(f"  {C('→')} {msg}")

_SEP = "─" * 60

def header(title: str) -> None:
    import time as _t
    ts = _t.strftime("%H:%M  %Y-%m-%d")
    print(f"\n  {_SEP}\n  {title}  {D(ts)}\n  {_SEP}")

def sect(title: str) -> None:
    print(f"\n  {B(title)}")


REPO = Path(__file__).resolve().parent
DATA = REPO / "data"
RULES_DIR = REPO / ".semgrep" / "rules"
FINDINGS_FILE = DATA / "semgrep_findings.json"

_R = "\033[0m"; _G = "\033[32m"; _Y = "\033[33m"
_RED = "\033[31m"; _DIM = "\033[2m"; _B = "\033[1m"; _C = "\033[36m"


def run_semgrep(quick: bool = False, rule_id: str = "") -> dict:
    """Run semgrep and return structured findings."""
    if not RULES_DIR.exists():
        return {"error": f"Rules directory not found: {RULES_DIR}"}

    cmd = [
        "semgrep",
        "--config", str(RULES_DIR),
        "backend/", "ms-testgen", "ms-coverage",
        "--json",
        "--quiet",
        "--no-git-ignore",
    ]
    if quick:
        cmd += ["--severity", "ERROR"]
    if rule_id:
        cmd += ["--rule", rule_id]

    result = subprocess.run(cmd, capture_output=True, text=True, cwd=str(REPO))

    try:
        data = json.loads(result.stdout) if result.stdout.strip() else {"results": []}
    except json.JSONDecodeError:
        data = {"results": [], "parse_error": result.stdout[:500]}

    findings = []
    for r in data.get("results", []):
        findings.append({
            "rule_id": r.get("check_id", ""),
            "file": r.get("path", ""),
            "line": r.get("start", {}).get("line", 0),
            "severity": r.get("extra", {}).get("severity", "WARNING"),
            "message": r.get("extra", {}).get("message", "")[:200],
            "core_rule": r.get("extra", {}).get("metadata", {}).get("core_rule", ""),
        })

    severity_counts = {"ERROR": 0, "WARNING": 0, "INFO": 0}
    for f in findings:
        sev = f["severity"].upper()
        severity_counts[sev] = severity_counts.get(sev, 0) + 1

    return {
        "tool": "semgrep",
        "generated_at": int(time.time()),
        "total": len(findings),
        "severity_counts": severity_counts,
        "findings": findings,
        "passed": severity_counts["ERROR"] == 0,
    }


def verify_rules() -> None:
    """Verify each rule matches at least one known instance (Core Rule 3.6)."""
    print(f"\n  Verifying rules match known instances…\n")

    # Known instances from Lessons Learned table — each rule must match ≥1
    known_instances = {
        "bare-db-commit": "db._c.commit()",
        "result-add-not-fail": 'result.add',
        "subprocess-shell-true": "shell=True",
    }

    rules_content = (RULES_DIR / "core-rules.yml").read_text()

    for rule_id, pattern in known_instances.items():
        if rule_id in rules_content:
            # Quick grep to confirm the pattern exists in code or tests
            grep = subprocess.run(
                ["grep", "-r", "--include=*.py", "-l", pattern, "backend/"],
                capture_output=True, text=True, cwd=str(REPO)
            )
            matched = grep.stdout.strip().splitlines()
            if matched:
                print(f"  {_G}✓{_R}  {rule_id}: matches {len(matched)} file(s)")
            else:
                print(f"  {_Y}!{_R}  {rule_id}: pattern not found in backend/ — rule may be too narrow")
        else:
            print(f"  {_RED}✗{_R}  {rule_id}: rule not defined in rules file")


def save_findings(findings: dict) -> None:
    DATA.mkdir(parents=True, exist_ok=True)
    FINDINGS_FILE.write_text(json.dumps(findings, indent=2))


def print_report(findings: dict) -> None:
    total = findings["total"]
    counts = findings["severity_counts"]
    errors = counts.get("ERROR", 0)
    warnings = counts.get("WARNING", 0)

    print(f"\n{'─'*60}")
    print(f"  {_B}Semgrep — Architectural Rule Enforcement{_R}")
    print(f"{'─'*60}")

    if total == 0:
        print(f"  {_G}✓{_R}  0 violations — all architectural rules respected")
    else:
        if errors:
            print(f"  {_RED}✗{_R}  {errors} ERROR(s), {warnings} WARNING(s) — Core Rules violated")
        else:
            print(f"  {_Y}!{_R}  {warnings} WARNING(s) — review recommended")

        for f in findings["findings"]:
            sev_color = _RED if f["severity"] == "ERROR" else _Y
            core = f" [Core Rule {f['core_rule']}]" if f["core_rule"] else ""
            print(f"\n  {sev_color}[{f['severity']}]{_R} {f['file']}:{f['line']}{core}")
            print(f"  {_DIM}{f['message'][:100]}{_R}")

    print(f"\n  Findings → {FINDINGS_FILE}")
    print(f"{'─'*60}\n")


def main() -> None:
    args = sys.argv[1:]
    quick = "--quick" in args
    verify = "--verify" in args
    rule_id = args[args.index("--rule") + 1] if "--rule" in args else ""

    if verify:
        verify_rules()
        return

    # Check semgrep is installed
    if subprocess.run(["which", "semgrep"], capture_output=True).returncode != 0:
        print(f"  {_Y}!{_R}  semgrep not installed")
        print(f"  Install: pip install semgrep --break-system-packages")
        sys.exit(1)

    print(f"\n  {_C}→{_R} Running architectural rule checks…", flush=True)
    findings = run_semgrep(quick=quick, rule_id=rule_id)

    if "error" in findings:
        print(f"  {_RED}✗{_R}  {findings['error']}")
        sys.exit(1)

    save_findings(findings)
    print_report(findings)

    # Auto-pipe to ms-audit if errors exist and AI available
    if not findings["passed"]:
        import os
        has_ai = (subprocess.run(
            ["curl", "-sf", "http://localhost:11434/api/tags"],
            capture_output=True
        ).returncode == 0 or os.environ.get("GROQ_API_KEY"))
        if has_ai:
            print(f"  {_C}→{_R}  Piping violations to ms-audit --improve…")
            subprocess.run([sys.executable, str(REPO / "ms-audit"),
                           "--improve", "--apply"], cwd=str(REPO))

    sys.exit(0 if findings["passed"] else 1)


if __name__ == "__main__":
    main()