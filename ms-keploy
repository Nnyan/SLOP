#!/usr/bin/env python3
"""ms-keploy — Mediastack Traffic Recording & Regression Capture

Records real API traffic from live sessions and auto-generates regression
tests. Every unique request/response pair becomes a test that can be
replayed to detect regressions.

Core Rule: 2.4 (proactive not reactive) — captures bugs from real sessions
before they're reported. Session sequences (multi-step wizard, health cycle,
app install → status check) are hard to synthesize but easy to capture.

Modes:
  record  — start recording (auto-stops after idle timeout or Ctrl+C)
  replay  — replay recorded sessions as regression tests
  export  — convert recordings to pytest test file
  status  — show recorded session count and latest captures

Usage:
  ms-keploy record              # record live traffic (runs until stopped)
  ms-keploy record --timeout 60 # auto-stop after 60s idle
  ms-keploy replay              # replay all recordings as tests
  ms-keploy export              # write tests/test_keploy_regression.py
  ms-keploy status              # show recording inventory

The server must be running. Recordings saved to data/keploy/

Install: sudo ln -sf /srv/mediastack/ms-keploy /usr/local/bin/ms-keploy
"""
from __future__ import annotations

import ast
import json
import os
