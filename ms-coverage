def _build_test_corpus() -> dict[str, tuple[str, str]]:
    """Build a corpus of all test content, keyed by test file."""
    corpus: dict[str, tuple[str, str]] = {}  # filepath → (content, kind)
    test_dir = REPO / "tests"
    if not test_dir.exists():
        return corpus
    for fpath in test_dir.rglob("test_*.py"):
        if ".venv" in fpath.parts:
            continue
        content = fpath.read_text()
        kind = "static"
        if any(k in content for k in ("TestClient", "StateDB()", "install_app(", "step_")):
            kind = "runtime"
        if any(k in content for k in ("E2E", "e2e", "test_client", "app_client")):
            kind = "e2e"
        corpus[str(fpath)] = (content, kind)
    return corpus


def _search_terms_for_node(node: CoverageNode) -> list[str]:
    """Generate search terms to look for in test files."""
    terms = []
    if node.kind == "route":
        # e.g. "GET /api/health/sources" → look for "sources", "health/sources", etc.
        parts = [p for p in node.label.split("/") if p and not p.startswith("{")]
        terms.extend(parts[-2:] if len(parts) >= 2 else parts)
        method = node.label.split(" ")[0].lower()
        terms.append(method)
        # Also look for handler name
        handler = re.search(r'handler=(\w+)', node.detail)
        if handler:
            terms.append(handler.group(1))
            terms.append(handler.group(1).replace("_", "-"))
    elif node.kind == "table":
        terms.append(node.label)
        terms.append(f'"{node.label}"')
        terms.append(f"FROM {node.label}")
    elif node.kind == "provider":
        cls = node.label
        terms.append(cls)
        terms.append(cls.replace("Provider", ""))
        terms.append(node.notes.split("file=")[-1] if "file=" in node.notes else "")
    elif node.kind == "manifest":
        terms.append(node.id.split(":")[-1])  # app key
        terms.append(node.label)
    elif node.kind == "step":
        terms.append(node.detail)  # step_function_name
        terms.append(node.detail.replace("step_", ""))
    elif node.kind == "view":
        terms.append(node.label)
        terms.append(node.file.split("/")[-1].replace(".vue", ""))
    elif node.kind == "tool":
        terms.append(node.label)
        terms.append(node.label.replace("-", "_"))
    return [t for t in terms if t and len(t) > 3]


def cross_reference_coverage(nodes: list[CoverageNode]) -> list[CoverageNode]:
    """Check each node against the test corpus."""
    corpus = _build_test_corpus()

    for node in nodes:
        terms = _search_terms_for_node(node)
        for fpath, (content, kind) in corpus.items():
            fname = Path(fpath).name
            if any(term in content for term in terms if len(term) > 3):
                node.covered = True
                node.test_count += content.count(terms[0]) if terms else 0
                if kind not in node.test_kinds:
                    node.test_kinds.append(kind)
                if fname not in node.test_files:
                    node.test_files.append(fname)

    return nodes


