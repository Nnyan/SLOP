def _rel(p: Path) -> str:
    try: return str(p.relative_to(REPO))
    except ValueError: return str(p)


def scan_routes() -> list[CoverageNode]:
    """Scan all FastAPI routers for route definitions."""
    nodes = []
    pattern = re.compile(
        r'@router\.(get|post|put|patch|delete|head|options)\("([^"]+)"',
        re.IGNORECASE
    )
    fn_pattern = re.compile(r'(?:async )?def (\w+)\(')

    for fpath in sorted((REPO / "backend/api").glob("*.py")):
        if fpath.name.startswith("_"):
            continue
        src = fpath.read_text()
        lines = src.splitlines()
        for i, line in enumerate(lines, 1):
            m = pattern.search(line)
            if not m:
                continue
            method = m.group(1).upper()
            path = m.group(2)
            # Find the function name on the next non-decorator line
            handler = "unknown"
            for j in range(i, min(i + 5, len(lines))):
                fm = fn_pattern.search(lines[j])
                if fm:
                    handler = fm.group(1)
                    break

            # Determine prefix from router include
            prefix = _infer_prefix(fpath.name)
            full_path = f"/api{prefix}{path}".replace("//", "/")

            # Risk heuristic
            risk = "low"
            if method in ("POST", "PUT", "DELETE", "PATCH"):
                risk = "medium"
            if any(w in path for w in ("reset", "approve", "install", "deploy", "wizard")):
                risk = "high"
            if any(w in path for w in ("reset/full", "approve", "execute")):
                risk = "critical"

            node_id = f"route:{method}:{full_path}"
            nodes.append(CoverageNode(
                id=node_id, kind="route",
                label=f"{method} {full_path}",
                detail=f"handler={handler}",
                file=_rel(fpath), line=i,
                covered=False, test_count=0,
                test_kinds=[], test_files=[],
                risk=risk, depends_on=[],
            ))
    return nodes


def _infer_prefix(filename: str) -> str:
    prefixes = {
        "health.py": "/health", "platform.py": "/platform",
        "apps.py": "/apps", "settings.py": "/settings",
        "catalog.py": "/catalog", "infra.py": "/infra",
        "routing.py": "/routing", "storage.py": "/storage",
        "models.py": "/models",
    }
    return prefixes.get(filename, "")


def scan_db_tables() -> list[CoverageNode]:
    """Scan schema.sql for all table definitions."""
    nodes = []
    schema = REPO / "backend/core/schema.sql"
    if not schema.exists():
        return nodes
    src = schema.read_text()
    lines = src.splitlines()
    tbl_pat = re.compile(r'CREATE TABLE IF NOT EXISTS (\w+)', re.IGNORECASE)
    col_pat = re.compile(r'^\s+(\w+)\s+(TEXT|INTEGER|REAL|BLOB|NUMERIC)', re.IGNORECASE)

    current_table = None
    current_cols: list[str] = []
    current_line = 0

    for i, line in enumerate(lines, 1):
        m = tbl_pat.search(line)
        if m:
            if current_table:
                _emit_table(nodes, current_table, current_cols, current_line, schema)
            current_table = m.group(1)
            current_cols = []
            current_line = i
        elif current_table:
            cm = col_pat.match(line)
            if cm and cm.group(1).lower() not in ("primary", "unique", "check", "foreign"):
                current_cols.append(cm.group(1))
            if line.strip().startswith(");"):
                _emit_table(nodes, current_table, current_cols, current_line, schema)
                current_table = None
                current_cols = []

    # Also scan for inline CREATE TABLE IF NOT EXISTS in Python
    for fpath in REPO.rglob("*.py"):
        if "test" in fpath.parts or ".venv" in fpath.parts:
            continue
        text = fpath.read_text()
        for m in tbl_pat.finditer(text):
            name = m.group(1)
            if not any(n.id == f"table:{name}" for n in nodes):
                line_no = text[:m.start()].count("\n") + 1
                nodes.append(CoverageNode(
                    id=f"table:{name}", kind="table",
                    label=name, detail="inline CREATE TABLE",
                    file=_rel(fpath), line=line_no,
                    covered=False, test_count=0,
                    test_kinds=[], test_files=[],
                    risk="medium", depends_on=[],
                    notes="created inline, not in schema.sql",
                ))
    return nodes


def _emit_table(nodes, name, cols, line_no, schema):
    risk = "low"
    if name in ("platform", "pending_fixes", "fix_history"):
        risk = "high"
    if name in ("apps", "health_checks", "operations"):
        risk = "critical"
    nodes.append(CoverageNode(
        id=f"table:{name}", kind="table",
        label=name, detail=f"cols: {', '.join(cols[:6])}{'…' if len(cols)>6 else ''}",
        file=_rel(schema), line=line_no,
        covered=False, test_count=0,
        test_kinds=[], test_files=[],
        risk=risk, depends_on=[],
    ))


def scan_providers() -> list[CoverageNode]:
    """Scan infra providers for class + deploy/remove/status methods."""
    nodes = []
    cls_pat = re.compile(r'class (\w+Provider)\(')
    for fpath in sorted((REPO / "backend/infra/providers").glob("*.py")):
        if fpath.name.startswith("_"):
            continue
        src = fpath.read_text()
        lines = src.splitlines()
        for i, line in enumerate(lines, 1):
            m = cls_pat.search(line)
            if not m:
                continue
            cls_name = m.group(1)
            # Determine slot from filename
            slot = fpath.stem.split("_")[0]
            risk = "high"  # all providers are high-risk (deploy/remove Docker)
            nodes.append(CoverageNode(
                id=f"provider:{cls_name}", kind="provider",
                label=cls_name, detail=f"slot={slot}",
                file=_rel(fpath), line=i,
                covered=False, test_count=0,
                test_kinds=[], test_files=[],
                risk=risk, depends_on=[f"route:POST:/api/platform/wizard/run"],
                notes=f"file={fpath.name}",
            ))
    return nodes


def scan_manifests() -> list[CoverageNode]:
    """Scan catalog YAML manifests."""
    nodes = []
    catalog_dir = REPO / "catalog/apps"
    if not catalog_dir.exists():
        return nodes
    try:
        import yaml
    except ImportError:
        yaml = None
    for fpath in sorted(catalog_dir.glob("*.yaml")):
        key = fpath.stem
        label = key
        if yaml:
            try:
                data = yaml.safe_load(fpath.read_text())
                label = data.get("display_name", key)
            except Exception:
                pass
        nodes.append(CoverageNode(
            id=f"manifest:{key}", kind="manifest",
            label=label, detail=f"catalog/{fpath.name}",
            file=_rel(fpath), line=1,
            covered=False, test_count=0,
            test_kinds=[], test_files=[],
            risk="medium",
            depends_on=["route:POST:/api/apps/install"],
        ))
    return nodes


def scan_wizard_steps() -> list[CoverageNode]:
    """Scan wizard.py for step functions."""
    nodes = []
    wizard = REPO / "backend/platform/wizard.py"
    if not wizard.exists():
        return nodes
    src = wizard.read_text()
    lines = src.splitlines()
    step_pat = re.compile(r'^def (step_\w+)\(inp')
    for i, line in enumerate(lines, 1):
        m = step_pat.match(line)
        if not m:
            continue
        fn = m.group(1)
        risk = "medium"
        if fn in ("step_traefik_deploy", "step_deploy_infra", "step_complete"):
            risk = "critical"
        if fn in ("step_network", "step_config_dirs", "step_write_env"):
            risk = "high"
        nodes.append(CoverageNode(
            id=f"step:{fn}", kind="step",
            label=fn.replace("step_", "").replace("_", " ").title(),
            detail=fn,
            file=_rel(wizard), line=i,
            covered=False, test_count=0,
            test_kinds=[], test_files=[],
            risk=risk,
            depends_on=["route:POST:/api/platform/wizard/run"],
        ))
    return nodes


def scan_frontend_views() -> list[CoverageNode]:
    """Scan Vue view files for components and their API calls."""
    nodes = []
    views_dir = REPO / "frontend/src/views"
    if not views_dir.exists():
        return nodes
    api_pat = re.compile(r'fetch\([\'"]([^\'"]+)[\'"]|[\'"]([^\'"]*api[^\'"]*)[\'"]', re.IGNORECASE)
    for fpath in sorted(views_dir.glob("*.vue")):
        src = fpath.read_text()
        api_calls = set()
        for m in api_pat.finditer(src):
            url = m.group(1) or m.group(2)
            if url and ("/api/" in url or url.startswith("/api")):
                api_calls.add(url.split("?")[0])

        risk = "medium"
        if "Setup" in fpath.stem or "Dashboard" in fpath.stem:
            risk = "high"

        nodes.append(CoverageNode(
            id=f"view:{fpath.stem}", kind="view",
            label=fpath.stem.replace("View", ""),
            detail=f"{len(api_calls)} API calls",
            file=_rel(fpath), line=1,
            covered=False, test_count=0,
            test_kinds=[], test_files=[],
            risk=risk,
            depends_on=list(api_calls)[:10],
            notes=", ".join(sorted(api_calls)[:5]),
        ))
    return nodes


def scan_tools() -> list[CoverageNode]:
    """Scan shell/python tools (ms-check, ms-update, ms-audit, ms-coverage)."""
    nodes = []
    for name in ("ms-check", "ms-update", "ms-audit", "ms-coverage", "ms-test.py"):
        fpath = REPO / name
        if not fpath.exists():
            continue
        risk = "high" if name in ("ms-update", "ms-audit") else "medium"
        nodes.append(CoverageNode(
            id=f"tool:{name}", kind="tool",
            label=name, detail="operational tool",
            file=_rel(fpath), line=1,
            covered=False, test_count=0,
            test_kinds=[], test_files=[],
            risk=risk, depends_on=[],
        ))
    return nodes




