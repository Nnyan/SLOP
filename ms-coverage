def identify_gaps(nodes: list[CoverageNode]) -> list[dict]:
    """Return uncovered high/critical nodes sorted by risk."""
    risk_order = {"critical": 0, "high": 1, "medium": 2, "low": 3}
    gaps = []
    for n in nodes:
        if not n.covered and n.risk in ("critical", "high"):
            gaps.append({
                "id": n.id, "kind": n.kind, "label": n.label,
                "risk": n.risk, "file": n.file, "line": n.line,
                "suggestion": _suggest_test(n),
            })
    return sorted(gaps, key=lambda g: risk_order.get(g["risk"], 9))


def _suggest_test(node: CoverageNode) -> str:
    if node.kind == "route":
        method = node.label.split()[0]
        path = node.label.split()[-1]
        return (f"Add test: client.{method.lower()}('{path}') → assert status 200 + response shape. "
                f"Add failure test: missing required fields → assert 422.")
    elif node.kind == "table":
        return (f"Add test: write a record to '{node.label}' → read it back → assert fields match. "
                f"Test: missing required column → assert IntegrityError handled gracefully.")
    elif node.kind == "provider":
        return (f"Add test: {node.label}().deploy(valid_cfg) → assert result.ok. "
                f"Add failure test: mock compose_up return (1, 'error') → assert not result.ok (no NameError).")
    elif node.kind == "step":
        return (f"Add test: {node.detail}(wizard_input) → run step → assert DB state or return value. "
                f"Add test: step with invalid input → assert result.ok=False + result.error set.")
    elif node.kind == "view":
        return (f"Add frontend contract test: verify all API calls made by {node.label}View.vue "
                f"exist as routes in the backend.")
    elif node.kind == "tool":
        return f"Add test: run {node.label} logic directly → assert key behaviors and output format."
    if node.kind == "rule":
        return (f"Add test: {node.detail.replace('test: ', '')}() — "
                f"prove this invariant: {node.label}")
    return f"Add behavioral test for {node.kind}: {node.label}"


