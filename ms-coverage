def build_summary(nodes: list[CoverageNode]) -> dict:
    by_kind: dict[str, dict] = {}
    for n in nodes:
        k = n.kind
        if k not in by_kind:
            by_kind[k] = {"total": 0, "covered": 0, "critical": 0, "high": 0}
        by_kind[k]["total"] += 1
        if n.covered:
            by_kind[k]["covered"] += 1
        if n.risk == "critical":
            by_kind[k]["critical"] += 1
        if n.risk == "high":
            by_kind[k]["high"] += 1

    total = len(nodes)
    covered = sum(1 for n in nodes if n.covered)
    pct = int(100 * covered / total) if total else 0

    return {
        "total": total, "covered": covered, "uncovered": total - covered,
        "coverage_pct": pct, "by_kind": by_kind,
        "critical_gaps": sum(1 for n in nodes if not n.covered and n.risk == "critical"),
        "high_gaps": sum(1 for n in nodes if not n.covered and n.risk == "high"),
    }


def get_commit() -> str:
    import subprocess
    try:
        return subprocess.run(["git", "-C", str(REPO), "rev-parse", "--short", "HEAD"],
                              capture_output=True, text=True).stdout.strip()
    except Exception:
        return "unknown"


def print_report(nodes: list[CoverageNode], gaps: list[dict], summary: dict):
    w = 62
    print(f"\n{'─'*w}")
    print(f"  Mediastack Coverage Map  ·  commit {get_commit()}")
    print(f"{'─'*w}")

    # Summary table
    kinds = ["route", "table", "provider", "manifest", "step", "view", "tool", "rule"]
    print(f"\n  {'Kind':<12} {'Total':>6} {'Covered':>8} {'Pct':>5}  {'Crit':>5} {'High':>5}")
    print(f"  {'─'*12} {'─'*6} {'─'*8} {'─'*5}  {'─'*5} {'─'*5}")
    for k in kinds:
        s = summary["by_kind"].get(k, {"total": 0, "covered": 0, "critical": 0, "high": 0})
        t, c = s["total"], s["covered"]
        if t == 0:
            continue
        pct = int(100 * c / t)
        bar_c = GREEN(f"{pct:3d}%") if pct >= 80 else (YELLOW(f"{pct:3d}%") if pct >= 50 else RED(f"{pct:3d}%"))
        crit = RED(str(s["critical"])) if s["critical"] else DIM("   0")
        high = YELLOW(str(s["high"])) if s["high"] else DIM("   0")
        print(f"  {k:<12} {t:>6} {c:>8} {bar_c}  {crit:>5} {high:>5}")

    total_pct = summary["coverage_pct"]
    bar = GREEN(f"{total_pct}%") if total_pct >= 70 else (YELLOW(f"{total_pct}%") if total_pct >= 40 else RED(f"{total_pct}%"))
    print(f"\n  Overall: {bar} ({summary['covered']}/{summary['total']} nodes covered)")
    print(f"  Critical gaps: {RED(str(summary['critical_gaps'])) if summary['critical_gaps'] else GREEN('0')}   "
          f"High gaps: {YELLOW(str(summary['high_gaps'])) if summary['high_gaps'] else GREEN('0')}")

    if gaps:
        print(f"\n  {'─'*w}")
        print(f"  Uncovered high-risk nodes (fix these first)")
        print(f"  {'─'*w}")
        for g in gaps[:20]:
            risk_badge = RED("CRIT") if g["risk"] == "critical" else YELLOW("HIGH")
            print(f"\n  [{risk_badge}] {BOLD(g['label'])} ({g['kind']})")
            print(f"    {DIM(g['file'])}:{g['line']}")
            print(f"    → {DIM(g['suggestion'][:80])}")
    else:
        print(f"\n  {GREEN('✓')} No critical/high gaps found")

    print(f"\n  Coverage map → {OUT}")
    print(f"{'─'*w}\n")


# ─────────────────────────────────────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────────────────────────────────────

def main():
    args = sys.argv[1:]
    json_only = "--json" in args
    gaps_only = "--gaps" in args
    section_filter = None
    if "--section" in args:
        idx = args.index("--section")
        section_filter = args[idx + 1] if idx + 1 < len(args) else None

    if not json_only:
        print(f"  → Scanning codebase…", end=" ", flush=True)

    # Collect all nodes
    nodes: list[CoverageNode] = []
    nodes.extend(scan_routes())
    nodes.extend(scan_db_tables())
    nodes.extend(scan_providers())
    nodes.extend(scan_manifests())
    nodes.extend(scan_wizard_steps())
    nodes.extend(scan_frontend_views())
    nodes.extend(scan_tools())
    nodes.extend(scan_rules())

    if section_filter:
        nodes = [n for n in nodes if n.kind == section_filter]

    # Cross-reference with tests
    nodes = cross_reference_coverage(nodes)

    if not json_only:
        print(f"done  {DIM(f'{len(nodes)} nodes scanned')}")
        print(f"  → Cross-referencing tests…", end=" ", flush=True)

    # Build output
    gaps = identify_gaps(nodes)
    summary = build_summary(nodes)

    if not json_only:
        cov_line = f"{summary['covered']}/{summary['total']} covered ({summary['coverage_pct']}%)"
        print(f"done  {DIM(cov_line)}")

    coverage_map = {
        "generated_at": int(time.time()),
        "commit": get_commit(),
        "nodes": [asdict(n) for n in nodes],
        "summary": summary,
        "gaps": gaps,
        "known_bugs": KNOWN_BUGS,
    }

    # Write JSON
    DATA.mkdir(parents=True, exist_ok=True)
    OUT.write_text(json.dumps(coverage_map, indent=2))

    if json_only:
        print(json.dumps(coverage_map, indent=2))
        return

    if gaps_only:
        for g in gaps:
            print(f"[{g['risk'].upper():8}] {g['kind']:<10} {g['label']}")
            print(f"           {g['file']}:{g['line']}")
            print(f"           {g['suggestion'][:100]}")
            print()
        return

    print_report(nodes, gaps, summary)


if __name__ == "__main__":
    main()
