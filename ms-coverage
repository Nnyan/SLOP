@dataclass
class CoverageNode:
    id: str            # unique identifier
    kind: str          # route | table | provider | manifest | view | step | tool
    label: str         # human-readable name
    detail: str        # path, method, file location
    file: str          # source file (relative to repo)
    line: int          # line number
    covered: bool      # has any test
    test_count: int    # number of tests touching this node
    test_kinds: list   # static | runtime | e2e | contract
    test_files: list   # which test files cover it
    risk: str          # low | medium | high | critical
    depends_on: list   # IDs this node depends on
    notes: str = ""    # any notable flags (deprecated, new, etc.)


@dataclass
class CoverageMap:
    generated_at: int
    commit: str
    nodes: list
    summary: dict
    gaps: list         # uncovered high-risk nodes
    recent_bugs: list  # bugs that were found by testing


