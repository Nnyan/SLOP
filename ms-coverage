def scan_rules() -> list[CoverageNode]:
    """Return CoverageNodes for all architectural rules.

    A rule is covered if its test_fn exists in its test_file.
    A rule with no test is a critical/high-risk gap.
    """
    nodes = []
    corpus = _build_test_corpus()
    corpus_combined = " ".join(content for content, _ in corpus.values())

    for rule in RULES:
        test_fn = rule["test_fn"]
        # Check if the test function exists anywhere in the test suite
        covered = f"def {test_fn}" in corpus_combined
        test_files = [
            Path(fp).name for fp, (content, _) in corpus.items()
            if f"def {test_fn}" in content
        ]

        nodes.append(CoverageNode(
            id=f"rule:{rule['id']}",
            kind="rule",
            label=rule["label"],
            detail=f"test: {test_fn}",
            file=rule["file"],
            line=1,
            covered=covered,
            test_count=1 if covered else 0,
            test_kinds=["runtime"] if covered else [],
            test_files=test_files,
            risk=rule["risk"],
            depends_on=[],
            notes=rule["rationale"][:120],
        ))
    return nodes

