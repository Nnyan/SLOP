# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
dist/
.pytest_cache/

# Node
node_modules/
frontend/dist/
frontend/.vite/

# Runtime / secrets
*.env
.env.*
!.env.example
*.db
*.db-journal

# Test VM SSH keys — operator-local, never commit; canonical location documented
# in docs/runbooks/test-vm-access.md
secrets/test-vm/vm-matrix-key
secrets/test-vm/vm-matrix-key.pub
secrets/test-vm/id_ed25519
secrets/test-vm/id_ed25519.pub
secrets/test-vm/*.bak.*

# Editor
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Build
*.log
.ms-test-history.json
TEST_ANALYSIS.md
ms-test.py.bak.*

# Frontend build artifacts — installer always rebuilds from source on fresh clone.
# The installer skip-on-current check (frontend.py:136) is existence-based, not
# currency-based: committed artifacts triggered the skip on fresh installs and caused
# the blank-page bug (rocinante, 2026-05). Gitignored in S-23-B.
backend/static/

# Runtime audit/test data — server-local, never commit
.ms-audit-history.json
.ms-audit-snapshot.json
.ms-trend-shown
.ms-self-improve-shown
.req_hash

data/last_test_run.json
data/last_ms_test_context.json
data/eslint_findings.json
# Per-app runtime data (general pattern). Add an explicit
# !data/<dir>/ exception below for any tracked subdirectory.
data/*/
!data/headscale/
!data/tailscale/
# Tailscale runtime state — not for a public repo.
# *.txt covers tailscaled.log1.txt, tailscaled.log2.txt; tailscaled.log.conf stays tracked.
data/tailscale/*.txt
data/tailscale/tailscaled.state
config/
# Community apps (user-installed, not tracked)
catalog/community/

# Hypothesis — database tracked, temp files not
hypothesis_db/.hypothesis/
.hypothesis/

# Regenerated by tooling on every run
data/coverage_map.json
data/state.db.bak.*

# Robot mode per-run output (see .claude/ROBOT.md). Archive or delete after
# morning review. Doctrine + defaults remain tracked at .claude/ROBOT.md and
# .claude/AUTONOMOUS-DEFAULTS.md.
.claude/run/
.claude/run-archive/
# Runtime scheduler lock — ephemeral, never shared (else it trips the Ring-0
# uncommitted-WIP check in check_push_status.sh as a false positive).
.claude/scheduled_tasks.lock

# Tooling caches — local to each dev environment, never shared
.mypy_cache/
# ruff lint/format cache — regenerated on every run
.ruff_cache/
# Per-agent worktree isolation scratch — never shared across contributors
.claude/worktrees/
