.DS_Store
Thumbs.db

# Build
*.log
.ms-test-history.json
TEST_ANALYSIS.md
ms-test.py.bak.*

# Frontend build artifacts — installer always rebuilds from source on fresh clone.
# The installer skip-on-current check (frontend.py:136) is existence-based, not
# currency-based: committed artifacts triggered the skip on fresh installs and caused
# the blank-page bug (rocinante, 2026-05). Gitignored in S-23-B.
# Run `git rm -r --cached backend/static/` before next release to remove from history.
backend/static/

# Runtime audit/test data — server-local, never commit
.ms-audit-history.json
.ms-audit-snapshot.json
.ms-trend-shown
.ms-self-improve-shown
.req_hash

data/last_test_run.json
data/last_ms_test_context.json
data/eslint_findings.json
# Per-app runtime data (general pattern). Add an explicit
# !data/<dir>/ exception below for any tracked subdirectory.
data/*/
!data/headscale/
!data/tailscale/
config/
# Community apps (user-installed, not tracked)
catalog/community/

# Hypothesis — database tracked, temp files not
hypothesis_db/.hypothesis/
.hypothesis/

# Regenerated by tooling on every run
data/coverage_map.json
data/state.db.bak.*
