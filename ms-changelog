#!/usr/bin/env python3
"""ms-changelog — Conventional Commits → CHANGELOG.md generator.

Modes:
  --init                Walk all history, produce CHANGELOG.md (replaces existing).
  --since <ref>         Unreleased section from <ref> to HEAD.
  --unreleased          Alias for --since <cutoff>~1.
  --check               Parse-only; exit non-zero on malformed post-cutoff commits.

Strategy ref: STEP_1_3_COMMIT_DISCIPLINE_STRATEGY.md §5; step 1.3.e.
"""
from __future__ import annotations

import argparse
import re
import subprocess
import sys
from pathlib import Path

# The Conventional Commits cutoff — first commit after the commit-msg hook
# was installed (step 1.3.c). Pre-cutoff commits are grandfathered.
CUTOFF_SHA = "4e4c9cb"

PATTERN = re.compile(
    r"^(?P<type>feat|fix|refactor|perf|test|docs|chore)"
    r"(?P<scope>\([a-z0-9_/\-]+\))?"
    r"(?P<breaking>!)?: "
    r"(?P<subject>[^\n]{1,100})$"
)

# CHANGELOG section by commit type. None = silent (no entry generated).
TYPE_SECTION = {
    "feat":     "Added",
    "fix":      "Fixed",
    "perf":     "Performance",
    "refactor": None,
    "test":     None,
    "docs":     None,
    "chore":    None,
}

BYPASS_PREFIXES = ("Merge ", 'Revert "', "fixup! ", "squash! ")


def _git(*args: str) -> str:
    return subprocess.run(
        ["git"] + list(args),
        capture_output=True, text=True, check=True,
    ).stdout


def parse(subject: str) -> dict[str, str] | None:
    """Parse a CC subject; return dict or None if malformed."""
    m = PATTERN.match(subject)
    if not m or subject.endswith("."):
        return None
    return {
        "type": m.group("type"),
        "scope": (m.group("scope") or "").strip("()"),
        "breaking": bool(m.group("breaking")),
        "subject": m.group("subject"),
    }


def commits_in(rev_range: str):
    """Yield (short_sha, subject) tuples for commits in rev_range."""
    out = _git("log", "--pretty=format:%h %s", rev_range)
    for line in out.splitlines():
        sha, _, subject = line.partition(" ")
        if sha and subject:
            yield sha, subject


def render_post_cutoff(commits, label: str = "Unreleased") -> list[str]:
    """Group post-cutoff CC commits into Keep-a-Changelog sections."""
    sections: dict[str, list[str]] = {"Added": [], "Fixed": [], "Performance": []}
    breaking: list[str] = []
    for _sha, _subject, parsed in commits:
        bullet = (
            f"- ({parsed['scope']}) {parsed['subject']}"
            if parsed["scope"] else f"- {parsed['subject']}"
        )
        if parsed["breaking"]:
            breaking.append(bullet)
        sec = TYPE_SECTION.get(parsed["type"])
        if sec:
            sections[sec].append(bullet)

    out = [f"## {label}", ""]
    if breaking:
        out += ["### BREAKING CHANGES", ""] + breaking + [""]
    for sec in ("Added", "Fixed", "Performance"):
        if sections[sec]:
            out += [f"### {sec}", ""] + sections[sec] + [""]
    if len(out) == 2:
        out += ["_No user-facing changes since cutoff._", ""]
    return out


def render_pre_policy(commits) -> list[str]:
    """Pre-cutoff commits as a flat list."""
    out = [
        f"## Pre-policy (commits before `{CUTOFF_SHA}`)",
        "",
        "These commits predate the Conventional Commits enforcement landing at",
        f"`{CUTOFF_SHA}` (step 1.3.c). Listed chronologically (newest first); no",
        "categorization. Per strategy doc — Core Rule 7.1 enforces the format",
        "from that SHA forward; pre-cutoff commits are grandfathered.",
        "",
    ]
    for sha, subject in commits:
        out.append(f"- `{sha}` {subject}")
    out.append("")
    return out


def cmd_init() -> int:
    """Generate full CHANGELOG.md."""
    post: list[tuple[str, str, dict]] = []
    for sha, subject in commits_in(f"{CUTOFF_SHA}~1..HEAD"):
        if subject.startswith(BYPASS_PREFIXES):
            continue
        parsed = parse(subject)
        if parsed:
            post.append((sha, subject, parsed))

    pre: list[tuple[str, str]] = []
    try:
        for sha, subject in commits_in(f"{CUTOFF_SHA}~1"):
            pre.append((sha, subject))
    except subprocess.CalledProcessError:
        pass

    header = (
        "# Changelog\n\n"
        "All notable changes to this project are documented in this file.\n"
        "The format follows [Keep a Changelog 1.1.0](https://keepachangelog.com/)\n"
        "and the project follows [Conventional Commits 1.0](https://www.conventionalcommits.org/).\n\n"
        f"Pre-policy commits (before `{CUTOFF_SHA}`) are listed at the end with no\n"
        "categorization. Per strategy\n"
        "[STEP_1_3_COMMIT_DISCIPLINE_STRATEGY.md](docs/cleanup/STEP_1_3_COMMIT_DISCIPLINE_STRATEGY.md)\n"
        "the commit-msg hook (Core Rule 7.1) enforces the format from that SHA\n"
        "forward; pre-policy commits are grandfathered.\n\n"
    )

    lines = [header]
    lines += render_post_cutoff(post, label="Unreleased")
    lines += render_pre_policy(pre)
    Path("CHANGELOG.md").write_text("\n".join(lines))
    print(f"CHANGELOG.md generated:")
    print(f"  post-cutoff (since {CUTOFF_SHA}): {len(post)} CC commits")
    print(f"  pre-policy:                       {len(pre)} commits")
    return 0


def cmd_since(ref: str) -> int:
    """Print Unreleased section from <ref> to HEAD."""
    commits = []
    for sha, subject in commits_in(f"{ref}..HEAD"):
        if subject.startswith(BYPASS_PREFIXES):
            continue
        parsed = parse(subject)
        if parsed:
            commits.append((sha, subject, parsed))
    print("\n".join(render_post_cutoff(commits, label="Unreleased")))
    return 0


def cmd_check() -> int:
    """Validate post-cutoff commits; exit non-zero on malformed."""
    bad: list[tuple[str, str]] = []
    for sha, subject in commits_in(f"{CUTOFF_SHA}~1..HEAD"):
        if subject.startswith(BYPASS_PREFIXES):
            continue
        if parse(subject) is None:
            bad.append((sha, subject))
    if bad:
        print(f"✗ {len(bad)} non-conforming post-cutoff commit(s):", file=sys.stderr)
        for sha, subject in bad:
            print(f"  {sha} {subject}", file=sys.stderr)
        return 1
    print(f"✓ All post-cutoff commits conform ({CUTOFF_SHA}~1..HEAD)")
    return 0


def main() -> int:
    ap = argparse.ArgumentParser(description=__doc__)
    g = ap.add_mutually_exclusive_group(required=True)
    g.add_argument("--init", action="store_true",
                   help="walk all history, produce CHANGELOG.md")
    g.add_argument("--since", metavar="REF",
                   help="Unreleased section from REF to HEAD")
    g.add_argument("--unreleased", action="store_true",
                   help="alias for --since <cutoff>~1")
    g.add_argument("--check", action="store_true",
                   help="parse-only; exit non-zero on malformed post-cutoff commits")
    args = ap.parse_args()
    if args.init:
        return cmd_init()
    if args.since:
        return cmd_since(args.since)
    if args.unreleased:
        return cmd_since(CUTOFF_SHA + "~1")
    if args.check:
        return cmd_check()
    return 0


if __name__ == "__main__":
    sys.exit(main())
