#!/usr/bin/env bash
# ms-update — update an installed SLOP/mediastack deployment in place.
#
# Pulls the latest code on the install dir (an HTTPS git clone of Nnyan/SLOP),
# reinstalls backend deps, rebuilds the frontend, and restarts the service.
#
# Usage:  sudo ms-update            # update to latest origin/main
#         sudo ms-update --status   # show current vs upstream, do not change
#         ms-update --help          # print usage and exit (touches nothing)
#
# Safe to run repeatedly and converges a diverged (history-rewritten) clone.
# Must be run as root (for systemctl) — it self-detects the service user and runs
# ALL git/pip/npm operations as that user; root is used only for systemctl + the
# ownership chown.
set -euo pipefail

# ---------------------------------------------------------------------------
# Paths / constants
# ---------------------------------------------------------------------------
REPO="${MS_INSTALL_DIR:-/opt/mediastack}"
SERVICE="mediastack"
BRANCH="${MS_BRANCH:-main}"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
log()  { printf '\033[1;34m[ms-update]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[ms-update] WARN:\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[1;31m[ms-update] ERROR:\033[0m %s\n' "$*" >&2; exit 1; }

usage() {
  cat <<'USAGE'
ms-update — update an installed SLOP/mediastack deployment in place.

Usage:
  sudo ms-update            update to latest origin/main, rebuild, restart
  sudo ms-update --status   show current vs upstream revision, change nothing
  ms-update --help          print this help and exit (touches nothing)

Environment:
  MS_INSTALL_DIR   install dir (default: /opt/mediastack)
  MS_BRANCH        upstream branch (default: main)
  MS_BUILD_HOME    writable HOME for the npm build (default: /tmp)

OPERATOR-ENV (reconcile w/ Stream C @ merge):
  Operator settings MS_TRUSTED_HOSTS / DOMAIN live in the install-dir .env
  (authoritative). To change them, edit "$MS_INSTALL_DIR/.env" then run
  `systemctl restart mediastack`. (The generated systemd unit carries
  EnvironmentFile=<install_dir>/.env.)
USAGE
}

# ---------------------------------------------------------------------------
# Argument parsing — --help is a guarded dry-run hook that touches nothing.
# ---------------------------------------------------------------------------
MODE="update"
case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
  --status)
    MODE="status"
    ;;
  "")
    MODE="update"
    ;;
  *)
    die "unknown argument: $1 (try --help)"
    ;;
esac

# ---------------------------------------------------------------------------
# Pre-flight checks
# ---------------------------------------------------------------------------
[[ -d "$REPO/.git" ]] || die "no git repo at $REPO (set MS_INSTALL_DIR?)"
command -v git >/dev/null 2>&1 || die "git not found"

# root is required for the update path (systemctl + chown). --status is read-only
# and may run unprivileged.
if [[ "$MODE" == "update" && $EUID -ne 0 ]]; then
  die "must run as root (try: sudo ms-update)"
fi

# ---------------------------------------------------------------------------
# Shared deploy helpers (single source of truth for service-user detection,
# build-HOME, and ownership normalization).
# ---------------------------------------------------------------------------
# shellcheck source=tools/deploy_lib.sh
source "$REPO/tools/deploy_lib.sh"

SVC_USER="$(detect_service_user "$REPO")"
log "service user: $SVC_USER"

# Run a git subcommand as the service user, in the repo, surfacing stderr.
svc_git() { sudo -u "$SVC_USER" git -C "$REPO" "$@"; }

# ---------------------------------------------------------------------------
# Current revision
# ---------------------------------------------------------------------------
CURRENT_REV="$(svc_git rev-parse HEAD 2>/dev/null || echo unknown)"
CURRENT_SHORT="$(svc_git rev-parse --short HEAD 2>/dev/null || echo unknown)"
log "current revision: $CURRENT_SHORT"

# ---------------------------------------------------------------------------
# Fetch upstream — surface failures (do NOT swallow stderr).
# ---------------------------------------------------------------------------
# Capture stderr so a fetch failure produces a real reason instead of dying
# silently under `set -e`. We temporarily disable errexit ONLY around the fetch
# so we can capture its status and message.
log "fetching origin/$BRANCH …"
set +e
FETCH_ERR="$(svc_git fetch origin "$BRANCH" --quiet 2>&1)"
FETCH_RC=$?
set -e
if [[ $FETCH_RC -ne 0 ]]; then
  die "fetch failed: ${FETCH_ERR:-unknown error (rc=$FETCH_RC)}"
fi

# ---------------------------------------------------------------------------
# Compare local vs upstream
# ---------------------------------------------------------------------------
LOCAL_REV="$(svc_git rev-parse HEAD 2>/dev/null || echo unknown)"
UPSTREAM_REV="$(svc_git rev-parse "origin/$BRANCH" 2>/dev/null || echo unknown)"
UPSTREAM_SHORT="$(svc_git rev-parse --short "origin/$BRANCH" 2>/dev/null || echo '?')"

if [[ "$MODE" == "status" ]]; then
  log "current:  $CURRENT_SHORT ($LOCAL_REV)"
  log "upstream: $UPSTREAM_SHORT ($UPSTREAM_REV)"
  if [[ "$LOCAL_REV" == "$UPSTREAM_REV" ]]; then
    log "up to date"
  else
    log "update available (run: sudo ms-update)"
  fi
  exit 0
fi

if [[ "$LOCAL_REV" == "$UPSTREAM_REV" && "$UPSTREAM_REV" != "unknown" ]]; then
  log "already up to date ($CURRENT_SHORT)"
  # Re-assert ownership in case a prior run (or manual op) left root-owned files,
  # and rebuild the frontend: backend/static/ is gitignored, so a prior failed
  # build may have left it stale/missing even when git is up to date.
  normalize_ownership "$REPO" "$SVC_USER" || warn "ownership normalize failed"
  log "rebuilding frontend (static is a gitignored artifact) …"
  if [[ -d "$REPO/frontend" ]]; then
    sudo -u "$SVC_USER" env HOME="$(build_home)" bash -c "cd '$REPO/frontend' && npm ci --silent && npm run build --silent" \
      || warn "frontend build failed"
  fi
  exit 0
fi

log "updating $CURRENT_SHORT → $UPSTREAM_SHORT"

# ---------------------------------------------------------------------------
# Pull / reset to upstream
# ---------------------------------------------------------------------------
# Try a fast-forward first; fall back to a hard reset if the clone has diverged
# (e.g. after a history rewrite). The reset path is ALWAYS reachable here — the
# fetch above already succeeded (or we exited), so origin/$BRANCH is fresh.
if ! svc_git merge --ff-only "origin/$BRANCH" --quiet; then
  warn "fast-forward failed (clone diverged); resetting --hard to origin/$BRANCH"
  svc_git reset --hard "origin/$BRANCH"
fi

# ---------------------------------------------------------------------------
# Post-update SHA-verify (fail loud) — a green "updated" must be falsifiable.
# ---------------------------------------------------------------------------
NEW_HEAD="$(svc_git rev-parse HEAD)"
EXPECTED="$(svc_git rev-parse "origin/$BRANCH")"
if [[ "$NEW_HEAD" != "$EXPECTED" ]]; then
  die "post-update SHA mismatch: HEAD=$NEW_HEAD but origin/$BRANCH=$EXPECTED — update did NOT land"
fi
log "verified HEAD == origin/$BRANCH ($(svc_git rev-parse --short HEAD))"

# ---------------------------------------------------------------------------
# Normalize ownership (single normalizer from deploy_lib.sh)
# ---------------------------------------------------------------------------
log "normalizing ownership …"
normalize_ownership "$REPO" "$SVC_USER" || warn "ownership normalize failed"

# ---------------------------------------------------------------------------
# Backend deps
# ---------------------------------------------------------------------------
log "installing backend deps …"
sudo -u "$SVC_USER" "$REPO/.venv/bin/pip" install -q -r "$REPO/requirements.txt" || warn "pip install failed"

# ---------------------------------------------------------------------------
# Frontend build — runs on every update (backend/static/ is a gitignored
# artifact that reset --hard removes), with a writable HOME for the service user.
# ---------------------------------------------------------------------------
log "building frontend …"
if [[ -d "$REPO/frontend" ]]; then
  sudo -u "$SVC_USER" env HOME="$(build_home)" bash -c "cd '$REPO/frontend' && npm ci --silent && npm run build --silent" \
    || warn "frontend build failed"
fi

# ---------------------------------------------------------------------------
# Restart service (the ONLY root operation besides the chown)
# ---------------------------------------------------------------------------
log "restarting $SERVICE …"
systemctl restart "$SERVICE" || die "failed to restart $SERVICE"

# ---------------------------------------------------------------------------
# Health check — read the canonical MS_PORT first, fall back to the legacy
# MEDIASTACK_PORT name with a one-line deprecation note (backward compat).
# ---------------------------------------------------------------------------
PORT="$(grep -E '^MS_PORT=' "$REPO/.env" 2>/dev/null | head -1 | cut -d= -f2 || true)"
if [[ -z "$PORT" ]]; then
  PORT="$(grep -E '^MEDIASTACK_PORT=' "$REPO/.env" 2>/dev/null | head -1 | cut -d= -f2 || true)"
  [[ -n "$PORT" ]] && warn "using legacy MEDIASTACK_PORT from .env; rename it to MS_PORT (deprecated)"
fi
PORT="${PORT:-8080}"

log "checking health on port $PORT …"
HEALTH_URL="http://127.0.0.1:${PORT}/api/v1/health/summary"
for _ in $(seq 1 30); do
  if curl -fsS "$HEALTH_URL" >/dev/null 2>&1; then
    log "service healthy ✓"
    exit 0
  fi
  sleep 1
done

warn "service did not become healthy within 30s"
exit 0
