#!/usr/bin/env bash
# ms-update — Pull latest Mediastack code and restart the service.
#
# Usage:
#   sudo ms-update           — standard update (smart recommendations with 5s countdown)
#   sudo ms-update --full    — update + run ALL test scripts immediately, no prompts
#   sudo ms-update --tests   — skip update, run test scripts only (no restart)
#
# Install once: sudo ln -sf /srv/mediastack/ms-update /usr/local/bin/ms-update

set -euo pipefail

# Flag parsing
_FULL_MODE=0    # --full: run all scripts immediately after update
_TESTS_ONLY=0   # --tests: skip update/restart, just run the test scripts
for _arg in "$@"; do
    case "$_arg" in
        --full)  _FULL_MODE=1 ;;
        --tests) _TESTS_ONLY=1; _FULL_MODE=1 ;;
        --help|-h)
            echo "Usage: sudo ms-update [--full] [--tests]"
            echo "  (no flags)  Standard update with smart recommendations"
            echo "  --full      Update + run ALL test scripts immediately"
            echo "  --tests     Skip update, run test scripts only"
            exit 0 ;;
    esac
done

# Self-detect install path — resolves through symlinks (e.g. /usr/local/bin/ms-update → /srv/mediastack)
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
REPO="$SCRIPT_DIR"

# ── Self-update: pull then re-exec if this script changed ──────────────────
# Bash buffers script files, so changes mid-run are invisible. Instead we pull
# silently at the very top and re-exec ourselves if ms-update was updated.
# The re-exec guard (_MS_REEXECED) prevents infinite loops.
# Capture OLD_COMMIT before any pull. Export it so it survives re-exec
# (when ms-update re-execs itself after updating, HEAD is already the new commit).
OLD_COMMIT=${OLD_COMMIT:-$(git -C "$REPO" rev-parse --short HEAD 2>/dev/null || echo "?")}
export OLD_COMMIT

if [[ "$_TESTS_ONLY" == "0" ]] && [[ -z "${_MS_REEXECED:-}" ]]; then
    _pre=$(git -C "$REPO" rev-parse HEAD 2>/dev/null || echo "")

    # ── Git sync: self-healing pull ───────────────────────────────────────
    # 1. .git ownership now handled by normalize-ownership.sh (called at step 6)

    # 2. Ensure we are on main branch (detached HEAD → pull does nothing)
    _BRANCH=$(git -C "$REPO" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
    if [[ "$_BRANCH" != "main" ]]; then
        echo "  ! Not on main branch ($_BRANCH) — switching"
        git -C "$REPO" checkout main 2>/dev/null || true
    fi

    # 3. Discard modified tracked files that would block fast-forward
    #    (runtime files that should be in .gitignore but may be tracked on older installs)
    git -C "$REPO" diff --name-only 2>/dev/null | while IFS= read -r _f; do
        if [[ "$_f" == data/* ]] || [[ "$_f" == config/* ]]; then
            git -C "$REPO" checkout -- "$_f" 2>/dev/null || true
        fi
    done

    # 4. Fetch + verify what remote has before pulling
    git -C "$REPO" fetch origin main --quiet 2>/dev/null
    _REMOTE_HEAD=$(git -C "$REPO" rev-parse origin/main 2>/dev/null || echo "")
    _LOCAL_HEAD=$(git -C "$REPO" rev-parse HEAD 2>/dev/null || echo "")

    if [[ -n "$_REMOTE_HEAD" ]] && [[ "$_REMOTE_HEAD" != "$_LOCAL_HEAD" ]]; then
        # Remote has new commits — attempt fast-forward pull first
        _pull_out=$(git -C "$REPO" pull origin main 2>&1)
        _pull_rc=$?
        if [[ $_pull_rc -ne 0 ]]; then
            echo "  ! git pull failed (rc=$_pull_rc) — forcing reset to origin/main"
            echo "    $_pull_out"
            # Force: reset hard to remote head (safe since we have no local commits)
            git -C "$REPO" reset --hard origin/main 2>/dev/null &&                 echo "  ! Force-synced to $(git -C "$REPO" rev-parse --short HEAD)" ||                 echo "  ✗ Force-sync failed — check git status"
        fi
    elif [[ -z "$_REMOTE_HEAD" ]]; then
        # Fetch failed (network/auth) — fall through with current code
        echo "  ! Could not reach origin — running with current code"
    fi
    # else: already up to date — nothing to do

    # 5. Post-pull verify: local HEAD must match remote
    _post=$(git -C "$REPO" rev-parse HEAD 2>/dev/null || echo "")
    _REMOTE_HEAD2=$(git -C "$REPO" rev-parse origin/main 2>/dev/null || echo "")
    if [[ -n "$_REMOTE_HEAD2" ]] && [[ "$_post" != "$_REMOTE_HEAD2" ]]; then
        echo "  ! WARNING: local $(git -C "$REPO" rev-parse --short HEAD) ≠ remote $(git -C "$REPO" rev-parse --short origin/main 2>/dev/null)"
        echo "    Run: sudo git -C $REPO reset --hard origin/main"
    fi

    # 6. Fix working-tree ownership (sudo git pull/reset creates root-owned
    #    files in the working tree; .git was handled in step 1 but the rest
    #    of the tree wasn't until now). Use the dedicated normalizer if
    #    present; fall back to a one-shot chown if it's not.
    _SVC_USER=$(stat -c "%U" "$REPO" 2>/dev/null || echo "stack")
    if [[ -x "$REPO/tools/normalize-ownership.sh" ]]; then
        "$REPO/tools/normalize-ownership.sh" --quiet 2>/dev/null || true
    else
        chown -R "${_SVC_USER}:${_SVC_USER}" "$REPO" 2>/dev/null || true
    fi

    if [[ "$_pre" != "$_post" ]] && git -C "$REPO" diff --name-only "$_pre" "$_post" 2>/dev/null | grep -q "^ms-update$"; then
        export _MS_REEXECED=1 OLD_COMMIT
        exec bash "$REPO/ms-update" "$@"
    fi
fi
VENV="$REPO/.venv"
SERVICE="mediastack"

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; CYAN='\033[0;36m'; RESET='\033[0m'
ok()   { echo -e "  ${GREEN}✓${RESET} $*"; }

# ── Install CLI symlinks (idempotent, requires sudo) ──────────────────────
for _tool in ms-check ms-audit ms-update; do
    _link="/usr/local/bin/$_tool"
    _target="$REPO/$_tool"
    if [[ -f "$_target" ]] && [[ ! -L "$_link" ]]; then
        ln -sf "$_target" "$_link" 2>/dev/null && ok "Installed $_tool → $_link" || true
    fi
done
warn() { echo -e "  ${YELLOW}!${RESET} $*"; }
err()  { echo -e "  ${RED}✗${RESET} $*" >&2; }
info() { echo -e "  ${CYAN}→${RESET} $*"; }

# ── Check for old data dir and warn ────────────────────────────────────────
OLD_DATA="/data/mediastack"

if systemctl is-active --quiet "$SERVICE" 2>/dev/null; then
    SVC_ENV=$(systemctl show "$SERVICE" -p EnvironmentFiles 2>/dev/null || echo "")
    SVC_DATA=$(systemctl show "$SERVICE" -p Environment 2>/dev/null | tr ' ' '\n' | grep MS_DATA_DIR= | cut -d= -f2 || echo "")
    if [[ "$SVC_DATA" == "$OLD_DATA" ]]; then
        echo
        warn "Service is reading data from $OLD_DATA (old install layout)"
        warn "Run ${CYAN}sudo $REPO/deploy.sh${RESET} once to migrate to the new layout"
        warn "Continuing update — using old data dir until migrated"
        echo
    fi
fi

# ── Check venv exists ───────────────────────────────────────────────────────
if [[ ! -f "$VENV/bin/pip" ]]; then
    warn "Virtualenv not found at $VENV"
    warn "Run ${CYAN}sudo $REPO/deploy.sh${RESET} first to set up the virtualenv"
    exit 1
fi

echo
info "Pulling latest code…"
# Pull already done at top of script; remaining refs already current

# Hash requirements.txt before and after pull — skip pip if unchanged
_REQ_HASH_BEFORE=$(md5sum "$REPO/requirements.txt" 2>/dev/null | cut -d" " -f1 || echo "")
_REQ_HASH_AFTER=$(md5sum "$REPO/requirements.txt" 2>/dev/null | cut -d" " -f1 || echo "")

if [[ -z "$_REQ_HASH_BEFORE" ]] || [[ "$_REQ_HASH_BEFORE" != "$(cat "$REPO/.req_hash" 2>/dev/null || echo '')" ]]; then
    info "Updating Python packages…"
    "$VENV/bin/pip" install -q -r "$REPO/requirements.txt"
    echo "$_REQ_HASH_AFTER" > "$REPO/.req_hash"
else
    ok "Python packages up to date (requirements.txt unchanged)"
fi

# Only restart if relevant files changed (backend code, requirements, manifests)
_CODE_CHANGED=0
if [[ -n "${_pre:-}" ]] && [[ "${_pre:-}" != "${_post:-}" ]]; then
    if git -C "$REPO" diff --name-only "${_pre}" "${_post}" 2>/dev/null | grep -qE "^(backend/|requirements|catalog/|ms-)"; then
        _CODE_CHANGED=1
    fi
else
    _CODE_CHANGED=1  # First run or git unavailable — always restart
fi

if [[ "$_CODE_CHANGED" == "1" ]]; then
    PREFIX="  ${CYAN}→${RESET} Restarting $SERVICE…     "
    printf "${PREFIX}               \r" >&2
    # Don't `|| true` silence systemctl — surface the warning. The
    # is-active poll below handles the actual readiness wait.
    systemctl restart "$SERVICE" || \
        printf "\n  ${YELLOW}WARN${RESET} systemctl restart returned non-zero — proceeding to readiness poll\n" >&2
    sleep 0.3
    _waited=0
    while [[ $_waited -lt 150 ]]; do
        systemctl is-active --quiet "$SERVICE" 2>/dev/null && break
        _bars=$(( (_waited / 10) % 15 + 1 ))
        _bar="$(printf '█%.0s' $(seq 1 $_bars))$(printf ' %.0s' $(seq 1 $((15-_bars))))"
        printf "\r${PREFIX}${GREEN}${_bar}${RESET}" >&2
        sleep 0.1
        _waited=$(( _waited + 1 ))
    done
    printf "\r${PREFIX}${GREEN}███████████████${RESET}\n" >&2

    # Poll for API readiness: TCP port check (fast) then one HTTP verify
    _API_PORT=$(grep -m1 '^MEDIASTACK_PORT=' "$REPO/.env" 2>/dev/null | cut -d= -f2 || echo "8080")
    _api_waited=0
    while [[ $_api_waited -lt 60 ]]; do
        # TCP check via /dev/tcp — no curl overhead, returns as soon as port is open
        if (echo > /dev/tcp/localhost/$_API_PORT) 2>/dev/null; then
            break
        fi
        sleep 0.2
        _api_waited=$(( _api_waited + 1 ))
    done
else
    ok "No backend changes — skipping service restart"
fi
if systemctl is-active --quiet "$SERVICE"; then
    NEW_COMMIT=$(git -C "$REPO" rev-parse --short HEAD 2>/dev/null || echo "unknown")
    # Strip type prefix, max 8 words, keep only one special char (first - or +)
    RAW=$(git -C "$REPO" log -1 --format="%s" 2>/dev/null | sed 's/^[^:]*: //' || echo "")
    SUBJECT=$(echo "$RAW" | awk '{
      # Keep up to 8 words
      out=""; words=0; special=0
      for(i=1;i<=NF;i++){
        w=$i
        # Count special chars (non-alphanumeric non-space, excluding ,.)
        if(match(w, /[-+]/)){
          if(special > 0) gsub(/[-+]/,"",w)
          else special++
        }
        if(words < 8){ out=(out=="")?w:out" "w; words++ }
      }
      print out
    }')
    TS=$(date "+%Y-%m-%d %H:%M")
    if [[ "$OLD_COMMIT" == "$NEW_COMMIT" ]]; then
        ok "up to date  ${CYAN}${NEW_COMMIT}${RESET}  (${TS})"
    else
        ok "update ${OLD_COMMIT} → ${NEW_COMMIT}: ${SUBJECT}  (${TS})"
    fi
    # Fix .env permissions (should be 600, not world-readable)
    if [[ -f "$REPO/.env" ]]; then
        ENV_PERM=$(stat -c "%a" "$REPO/.env" 2>/dev/null || echo "")
        if [[ "$ENV_PERM" != "600" ]]; then
            chmod 600 "$REPO/.env"
            ok ".env permissions fixed (600)"
        fi
    fi

    # CLI symlinks installed at startup (above)


    # ── Unified health check + test summary ──────────────────────────────
    _SEP="────────────────────────────────────────────────────────────"
    _NEW_COMMIT=$(git -C "$REPO" rev-parse --short HEAD 2>/dev/null || echo "?")
    _TS=$(date "+%H:%M  %Y-%m-%d")

    echo ""
    printf "  %s\n" "$_SEP"
    printf "  Mediastack Health  %s\n" "$_NEW_COMMIT"
    printf "  %s\n" "$_SEP"

    _SVC_STATE=$(systemctl is-active "$SERVICE" 2>/dev/null || echo "unknown")
    [[ "$_SVC_STATE" == "active" ]] && ok "Service: running" || fail "Service: $_SVC_STATE"

    _API_PORT=$(grep -m1 "^MEDIASTACK_PORT=" "$REPO/.env" 2>/dev/null | cut -d= -f2 || echo "8080")
    if curl -sf --max-time 2 "http://localhost:${_API_PORT}/api/platform/status" >/dev/null 2>&1; then
        ok "API: reachable on port $_API_PORT"
    else
        warn "API: not responding on port $_API_PORT"
    fi

    _COV_FILE="$REPO/data/coverage_map.json"
    if [[ -f "$_COV_FILE" ]]; then
        _COV_PCT=$(python3 -c "import json;d=json.load(open('$_COV_FILE'));print(d['summary']['coverage_pct'])" 2>/dev/null || echo "?")
        _COV_CRIT=$(python3 -c "import json;d=json.load(open('$_COV_FILE'));print(d['summary']['critical_gaps'])" 2>/dev/null || echo "0")
        [[ "$_COV_CRIT" == "0" ]] && ok "Coverage: ${_COV_PCT}% · 0 critical gaps" || fail "Coverage: ${_COV_PCT}% · ${_COV_CRIT} critical gap(s)"
    fi

    _BEHIND=$(git -C "$REPO" rev-list --count HEAD..origin/main 2>/dev/null || echo "0")
    [[ "$_BEHIND" == "0" ]] && ok "Git: in sync with origin/main" || warn "Git: ${_BEHIND} commit(s) behind origin/main"

    # ── Structural anti-pattern audit ────────────────────────────────────
    if [[ -f "$REPO/tools/check_structural_antipatterns.py" ]]; then
        _STRUCT=$(python3 "$REPO/tools/check_structural_antipatterns.py" --audit 2>/dev/null || echo "Structural audit: error")
        if [[ "$_STRUCT" == "Structural audit: clean" ]]; then
            ok "Structural audit: clean"
        else
            warn "Structural audit: findings — run python3 tools/check_structural_antipatterns.py --audit"
        fi
    fi

    _FAILS=0; _FAIL_NAMES=""
    _LAST_RUN="$REPO/data/last_test_run.json"
    if [[ -f "$_LAST_RUN" ]]; then
        _FAILS=$(python3 -c "import json,pathlib; d=json.loads(pathlib.Path('$_LAST_RUN').read_text()); print(d.get('failed',0))" 2>/dev/null || echo "0")
        _FAIL_NAMES=$(python3 -c "
import json,pathlib
d=json.loads(pathlib.Path('$_LAST_RUN').read_text())
failures=d.get('failures',[])
print(', '.join(failures[:3]) if failures else '')
" 2>/dev/null || echo "")
    fi
    printf "  %s\n" "$_SEP"
    if [[ "$_FAILS" == "0" ]]; then
        if [[ "$OLD_COMMIT" == "$_NEW_COMMIT" ]]; then
            printf "  \033[0;32m✓\033[0m  %s :: %s (up to date)\n" "$_TS" "$_NEW_COMMIT"
        else
            printf "  \033[0;32m✓\033[0m  %s :: %s \033[0;36m→\033[0m %s\n" "$_TS" "$OLD_COMMIT" "$_NEW_COMMIT"
        fi
    else
        printf "  \033[1;33m!\033[0m %s test(s) failed  %s :: %s \033[0;36m→\033[0m %s\n" "$_FAILS" "$_TS" "$OLD_COMMIT" "$_NEW_COMMIT"
        [[ -n "$_FAIL_NAMES" ]] && printf "  \033[2m  Failed: %s\033[0m\n" "$_FAIL_NAMES"
    fi
    echo

    # ── Self-heal: orphaned records, ghost fragments, stale health, history prune ──
    "$VENV/bin/python3" "$REPO/backend/scripts/self_heal.py" "$REPO"


    # ── Pytest scratch cleanup (older than 7 days) ──────────────────────────
    find /tmp/pytest-of-stack /srv/tmp/pytest-base -maxdepth 1 -mindepth 1 -mtime +7 -exec rm -rf {} + 2>/dev/null || true

    # ── Smart post-update recommendations ───────────────────────────────
    "$VENV/bin/python3" "$REPO/backend/scripts/update_recommendations.py" "$REPO" "${_pre:-}" "${_post:-}" "${VENV}" "${_FULL_MODE}"

    echo
else
    err "Service failed to start. Check: journalctl -u $SERVICE -n 30"
    exit 1
fi
