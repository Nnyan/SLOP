#!/usr/bin/env python3
"""ms-enforce — Core Rules Compliance Oracle

Runs every enforcement layer in dependency order. Fails on any violation.

  Tier 0 (instant): Semgrep + coverage rule gaps
  Tier 1 (~15s):    Path contracts + Catalog + Ruff + Bandit
  Tier 2 (~30s):    FSM tests + test collection

Usage:
  ms-enforce           # full (Tier 0+1+2)
  ms-enforce --fast    # Tier 0+1 only (pre-commit)
  ms-enforce --list    # show all rules

Install: sudo ln -sf /srv/mediastack/ms-enforce /usr/local/bin/ms-enforce
"""
from __future__ import annotations

import ast
import json
import re
import subprocess
import sys
import time
from pathlib import Path

REPO = Path(__file__).resolve().parent

_RESET = "\033[0m"
_BOLD = "\033[1m"
_DIM = "\033[2m"
_GREEN = "\033[0;32m"
_YELLOW = "\033[1;33m"
_RED = "\033[0;31m"
_CYAN = "\033[0;36m"


def G(s: str) -> str: return f"{_GREEN}{s}{_RESET}"
def R(s: str) -> str: return f"{_RED}{s}{_RESET}"
def Y(s: str) -> str: return f"{_YELLOW}{s}{_RESET}"
def D(s: str) -> str: return f"{_DIM}{s}{_RESET}"
def B(s: str) -> str: return f"{_BOLD}{s}{_RESET}"
def C(s: str) -> str: return f"{_CYAN}{s}{_RESET}"


def ok(msg: str)   -> None: print(f"  {G(chr(10003))} {msg}")
def fail(msg: str) -> None: print(f"  {R(chr(10007))} {msg}")
def info(msg: str) -> None: print(f"  {C(chr(8594))} {msg}")


_SEP = chr(9472) * 60


def header(title: str) -> None:
    ts = time.strftime("%H:%M  %Y-%m-%d")
    print(f"\n  {_SEP}\n  {title}  {D(ts)}\n  {_SEP}")


def sect(title: str) -> None:
    print(f"\n  {B(title)}")


def _run(cmd: list[str], timeout: int = 60) -> tuple[int, str]:
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, cwd=str(REPO), timeout=timeout)
        return r.returncode, r.stdout + r.stderr
    except subprocess.TimeoutExpired:
        return 1, f"timeout after {timeout}s"
    except Exception as exc:
        return 1, str(exc)


def _bad_lines(out: str, *markers: str) -> list[str]:
    return [x for x in out.splitlines() if any(m in x for m in markers)][:3]


# ── Tier 0 ────────────────────────────────────────────────────────────────

def check_semgrep() -> tuple[bool, str]:
    rules_dir = REPO / ".semgrep" / "rules"
    if not rules_dir.exists():
        return True, "semgrep rules not found (skip)"
    _, out = _run(["semgrep", "--config", str(rules_dir),
                   "backend/", "ms-testgen", "ms-coverage", "ms-test.py",
                   "--json", "--quiet", "--no-git-ignore"])
    try:
        data = json.loads(out.splitlines()[0] if "\n" in out else out)
        errors = [r for r in data.get("results", [])
                  if r.get("extra", {}).get("severity") == "ERROR"]
        if errors:
            detail = "\n".join(
                f"    {e['path']}:{e['start']['line']} "
                f"[{e['extra'].get('metadata',{}).get('core_rule','?')}] "
                f"{e['extra']['message'][:70]}"
                for e in errors[:5])
            return False, f"{len(errors)} violation(s):\n{detail}"
        return True, "0 architectural violations"
    except Exception:
        return True, "semgrep not available (skip)"


def check_coverage_rules() -> tuple[bool, str]:
    cov_file = REPO / "data" / "coverage_map.json"
    _run(["python3", str(REPO / "ms-coverage"), "--json"], timeout=30)
    if not cov_file.exists():
        return True, "coverage map not found (skip)"
    data = json.loads(cov_file.read_text())
    rules = [n for n in data["nodes"] if n["kind"] == "rule"]
    critical = [n for n in rules if not n["covered"] and n["risk"] == "critical"]
    high = [n for n in rules if not n["covered"] and n["risk"] == "high"]
    if critical:
        detail = "\n".join(f"    [critical] {n['label']}" for n in critical[:5])
        return False, f"{len(critical)} critical rule(s) uncovered:\n{detail}"
    if high:
        detail = "\n".join(f"    [high] {n['label']}" for n in high[:3])
        return False, f"{len(high)} high rule(s) uncovered:\n{detail}"
    return True, f"{len(rules)}/{len(rules)} architectural rules covered"


# ── Tier 1 ────────────────────────────────────────────────────────────────

def _pytest_check(test_id: str, label: str, timeout: int = 30) -> tuple[bool, str]:
    _, out = _run(["python3", "-m", "pytest", test_id, "-q", "--tb=short", "--no-header"],
                  timeout=timeout)
    if "passed" in out and "failed" not in out:
        return True, label
    bad = _bad_lines(out, "FAILED", "AssertionError", "Error")
    return False, "failed:\n" + "\n".join(f"    {x}" for x in bad)


def check_path_contracts() -> tuple[bool, str]:
    return _pytest_check(
        "tests/test_comprehensive_contracts.py::TestPathContractAlignment",
        "test paths match production write paths")


def check_catalog_compliance() -> tuple[bool, str]:
    return _pytest_check(
        "tests/test_non_catalog_installs.py::TestCatalogCompliance",
        "all catalog apps compliant")


def check_ruff() -> tuple[bool, str]:
    # Block only on codes that cause runtime crashes:
    #   F821 = undefined name (NameError at runtime)
    #   E999 = syntax error (won't import at all)
    # Style, convention, and bugbear codes are handled by the pre-commit
    # hook separately and don't block the architectural compliance check.
    _, out = _run(["python3", "-m", "ruff", "check", "backend/", "backend/scripts/",
                   "--select", "F821,E999", "--output-format=json"])
    try:
        results = json.loads(out) if out.strip().startswith("[") else []
        if results:
            s = results[0]
            return False, (f"{len(results)} crash-risk error(s) — "
                           f"{s['filename'].split('/')[-1]}:{s['location']['row']} "
                           f"[{s['code']}] {s['message'][:60]}")
        return True, "0 undefined names or syntax errors"
    except Exception:
        return True, "ruff not available (skip)"


def check_bandit() -> tuple[bool, str]:
    _, out = _run(["python3", "-m", "bandit", "-r", "backend/", "-f", "json", "-ll", "-ii"])
    try:
        data = json.loads(out) if out.strip().startswith("{") else {"results": []}
        high = [r for r in data.get("results", [])
                if r.get("issue_severity") in ("HIGH", "CRITICAL")
                and r.get("issue_confidence") == "HIGH"]
        if high:
            s = high[0]
            return False, (f"{len(high)} high-severity issue(s) — "
                           f"{s['filename']}:{s['line_number']} [{s['test_id']}]")
        return True, "0 high-severity security issues"
    except Exception:
        return True, "bandit not available (skip)"




def check_write_read_cycles() -> tuple[bool, str]:
    """Core Rule 2.8: key I/O boundaries have write-read cycle tests."""
    _, out = _run([
        "python3", "-m", "pytest",
        "tests/test_comprehensive_contracts.py::TestComposeFragmentWriteReadCycle",
        "tests/test_comprehensive_contracts.py::TestTableNameConstants",
        "tests/test_comprehensive_contracts.py::TestToolFindingsSchema",
        "tests/test_comprehensive_contracts.py::TestPathContractAlignment",
        "-q", "--tb=short", "--no-header",
    ], timeout=30)
    if "passed" in out and "failed" not in out:
        return True, "all write-read cycle contracts hold"
    bad = [x for x in out.splitlines() if "FAILED" in x or "AssertionError" in x][:3]
    return False, "write-read cycle broken: " + " | ".join(bad)

def check_precondition_declarations() -> tuple[bool, str]:
    """Core Rule 2.9: tests declare preconditions via section_requires()."""
    ms_test = REPO / 'ms-test.py'
    if not ms_test.exists():
        return True, 'ms-test.py not found (skip)'
    src = ms_test.read_text()
    if '_populate_context' not in src:
        return False, 'ms-test.py missing _populate_context() — precondition system not installed'
    if 'section_requires' not in src:
        return False, 'ms-test.py missing section_requires() — precondition guard not installed'
    if '_populate_context()  # Core Rule 2.9' not in src:
        return False, '_populate_context() not called in main() — preconditions never set'
    if 'section_requires("platform_status"' not in src:
        return False, 'Q3 must use section_requires(platform_status) not bare if/else'
    _, out = _run([
        'python3', '-m', 'pytest',
        'tests/test_comprehensive_contracts.py::TestQ3ComposeFragmentInvariant',
        '-q', '--tb=short', '--no-header',
    ], timeout=30)
    if 'passed' in out and 'failed' not in out:
        return True, 'precondition system present and Q3 invariant verified'
    bad = [x for x in out.splitlines() if 'FAILED' in x or 'Error' in x][:3]
    return False, 'precondition test failed: ' + ' | '.join(bad)


def check_shellcheck() -> tuple[bool, str]:
    """ShellCheck: structural shell script bugs (bad substitutions, unquoted vars)."""
    import subprocess as _sp
    if _sp.run(["which", "shellcheck"], capture_output=True).returncode != 0:
        return True, "shellcheck not installed (sudo apt-get install shellcheck)"
    shell_scripts = ["ms-check", "ms-update", "ms-test-all", "ms-setup-tools"]
    errors = []
    for script in shell_scripts:
        p = REPO / script
        if not p.exists(): continue
        r = _sp.run(["shellcheck", "-S", "error", str(p)],
                    capture_output=True, text=True, cwd=str(REPO))
        if r.returncode != 0:
            for line in r.stdout.splitlines():
                if "SC" in line and "error" in line.lower():
                    errors.append(f"{script}: {line.strip()[:80]}")
    if errors:
        detail = "\n".join(f"    {e}" for e in errors[:5])
        return False, f"{len(errors)} shell error(s):\n{detail}"
    return True, f"{len(shell_scripts)} shell scripts clean"


def check_heredoc_python() -> tuple[bool, str]:
    """Python in shell heredocs is invisible to Ruff/Semgrep/Bandit — must be extracted."""
    import re
    violations = []
    for script in REPO.glob("ms-*"):
        if not script.is_file(): continue
        try:
            content = script.read_text()
        except Exception:
            continue
        matches = re.findall(r"python3.*<<.*?'([A-Z_]+)'\n(.*?)\n\1", content, re.DOTALL)
        for _, py_content in matches:
            py_lines = len([l for l in py_content.splitlines() if l.strip()])
            if py_lines > 20:
                violations.append(f"{script.name}: {py_lines} Python lines in heredoc")
    if violations:
        return False, "Python heredocs >20 lines (invisible to tools): " + " | ".join(violations)
    return True, "no large Python heredocs in shell scripts"


def check_refactor_coverage() -> tuple[bool, str]:
    """Verify no refactoring dropped behaviors (Core Rule 2.10)."""
    rc, out = _run(["python3", str(REPO / "ms-refactor"), "verify-heredocs"], timeout=15)
    if rc != 0:
        bad = [x for x in out.splitlines() if chr(10007) in x][:3]
        return False, "refactor dropped behaviors: " + " | ".join(bad)
    return True, "all extractions maintain complete behavior coverage"


# ── Migration checks (Core Rule 5.19 / 6.1) ──────────────────────────────

_MIGRATION_NAME_RE = re.compile(r"^(\d{3})_[a-z0-9_]+\.(sql|py)$")

# Files where CREATE TABLE IF NOT EXISTS is permitted
_ALLOWED_CREATE_TABLE = {
    REPO / "backend" / "core" / "schema.sql",
    REPO / "backend" / "core" / "migrations.py",   # schema_migrations bootstrap only
}
_ALLOWED_CREATE_TABLE_DIRS = {REPO / "migrations"}
# Known legacy files scheduled for cleanup (§9 of design doc)
_LEGACY_CREATE_TABLE = {
    REPO / "backend" / "api" / "health.py",
    REPO / "backend" / "api" / "models.py",
    REPO / "backend" / "health" / "checker.py",
    REPO / "backend" / "health" / "source_checker.py",
    REPO / "backend" / "health" / "managed_services.py",
    REPO / "backend" / "api" / "quickstart.py",
}


def check_migration_sequence() -> tuple[bool, str]:
    """Core Rule 6.1: migration version numbers are strictly monotonic (no gaps, no duplicates)."""
    mig_dir = REPO / "migrations"
    if not mig_dir.exists():
        return False, "migrations/ directory not found"
    files: list[tuple[int, str]] = []
    for p in mig_dir.iterdir():
        if p.is_dir():
            continue
        m = _MIGRATION_NAME_RE.match(p.name)
        if m:
            files.append((int(m.group(1)), p.name))
    if not files:
        return False, "no migration files found in migrations/"
    files.sort()
    seen: dict[int, str] = {}
    issues: list[str] = []
    for version, name in files:
        if version in seen:
            issues.append(f"duplicate version {version:03d}: {seen[version]} and {name}")
        seen[version] = name
    versions = sorted(v for v, _ in files)
    for i in range(1, len(versions)):
        if versions[i] != versions[i - 1] + 1:
            issues.append(
                f"gap: {versions[i - 1]:03d} → {versions[i]:03d} "
                f"(missing {versions[i - 1] + 1:03d})"
            )
    if issues:
        return False, "; ".join(issues)
    return True, f"{len(files)} migration(s), sequence {versions[0]:03d}–{versions[-1]:03d} clean"


def check_py_migration_api() -> tuple[bool, str]:
    """Core Rule 6.1: every .py migration exports def upgrade(conn)."""
    mig_dir = REPO / "migrations"
    if not mig_dir.exists():
        return True, "migrations/ not found (skip)"
    issues: list[str] = []
    for p in mig_dir.iterdir():
        if p.suffix != ".py" or not _MIGRATION_NAME_RE.match(p.name):
            continue
        try:
            tree = ast.parse(p.read_text(encoding="utf-8"), filename=str(p))
        except SyntaxError as e:
            issues.append(f"{p.name}: SyntaxError — {e}")
            continue
        top_fns = {
            node.name
            for node in ast.walk(tree)
            if isinstance(node, ast.FunctionDef) and node.col_offset == 0
        }
        if "upgrade" not in top_fns:
            issues.append(f"{p.name}: missing top-level def upgrade(conn)")
    if issues:
        return False, "; ".join(issues)
    checked = sum(1 for p in mig_dir.iterdir()
                  if p.suffix == ".py" and _MIGRATION_NAME_RE.match(p.name))
    return True, f"{checked} .py migration(s) expose upgrade(conn)"


def check_schema_sql_sync() -> tuple[bool, str]:
    """Core Rule 6.1: schema.sql matches what migrations/ would generate."""
    regen = REPO / "tools" / "regenerate-schema-sql.py"
    if not regen.exists():
        return False, "tools/regenerate-schema-sql.py not found — run step 1.1.d"
    rc, out = _run(["python3", str(regen), "--check"], timeout=30)
    if rc != 0:
        first_line = next((l for l in out.splitlines() if l.strip()), out[:120])
        return False, f"schema.sql out of sync — run: python3 tools/regenerate-schema-sql.py\n    {first_line}"
    return True, "schema.sql in sync with migrations/"


def check_no_adhoc_create() -> tuple[bool, str]:
    """Core Rule 6.1: no new CREATE TABLE IF NOT EXISTS outside migrations/ or schema.sql."""
    pattern = re.compile(r"CREATE\s+TABLE\s+IF\s+NOT\s+EXISTS", re.IGNORECASE)
    issues: list[str] = []
    for path in sorted((REPO / "backend").rglob("*.py")):
        if path in _ALLOWED_CREATE_TABLE or path in _LEGACY_CREATE_TABLE:
            continue
        if any(path.is_relative_to(d) for d in _ALLOWED_CREATE_TABLE_DIRS):
            continue
        try:
            text = path.read_text(encoding="utf-8", errors="replace")
        except OSError:
            continue
        for lineno, line in enumerate(text.splitlines(), 1):
            if pattern.search(line):
                rel = path.relative_to(REPO)
                issues.append(f"{rel}:{lineno} — schema changes go in migrations/ (Core Rule 6.1)")
    if issues:
        return False, "\n".join(f"    {i}" for i in issues[:5])
    return True, "no ad-hoc CREATE TABLE IF NOT EXISTS outside permitted files"

# ── Tier 2 ────────────────────────────────────────────────────────────────

def check_fsm_tests() -> tuple[bool, str]:
    rc, out = _run([
        "python3", "-m", "pytest",
        "tests/test_fsm_app_install.py",
        "tests/test_fsm_platform.py",
        "tests/test_fsm_health_check.py",
        "-q", "--tb=short", "--no-header",
    ], timeout=90)
    failed = 0
    for line in out.splitlines():
        if "failed" in line and line.strip()[:1].isdigit():
            try:
                failed = int(line.strip().split()[0])
            except ValueError:
                pass
    if rc != 0 or failed > 0:
        bad = _bad_lines(out, "FAILED")
        return False, f"{failed} FSM test(s) failed:\n" + "\n".join(f"    {x}" for x in bad)
    return True, "all FSM tests pass — state machine invariants hold"


def check_test_collection() -> tuple[bool, str]:
    rc, out = _run([
        "python3", "-m", "pytest", "tests/", "--co", "-q", "--no-header",
        "--ignore=tests/test_integration.py", "--ignore=tests/browser/",
    ], timeout=30)
    if rc != 0:
        bad = _bad_lines(out, "ERROR")
        return False, "collection errors:\n" + "\n".join(f"    {x}" for x in bad)
    count = 0
    for line in out.splitlines():
        match = re.search(r"(\d+) test", line)
        if match:
            count = int(match.group(1))
    return True, f"{count or '?'} tests collect cleanly"


# ── Runner ────────────────────────────────────────────────────────────────

TIER_0: list[tuple[str, object]] = [
    ("Semgrep — architectural violations", check_semgrep),
    ("Coverage — rule gaps",               check_coverage_rules),
]
TIER_1: list[tuple[str, object]] = [
    ("Path contracts (Core Rule 3.9)",     check_path_contracts),
    ("Catalog compliance (Core Rule 5.5)", check_catalog_compliance),
    ("Ruff — Python correctness",          check_ruff),
    ("Bandit — Python security",           check_bandit),
    ("Write-read cycles (Core Rule 2.8)",    check_write_read_cycles),
    ("Precondition guards (Core Rule 2.9)",   check_precondition_declarations),
    ("ShellCheck — shell script errors",          check_shellcheck),
    ("Python in heredocs",                         check_heredoc_python),
    ("Refactor coverage (Core Rule 2.10)",         check_refactor_coverage),
    # ── Migration discipline (Core Rule 6.1) added by step 1.1.g ──────────
    ("Migration sequence (Core Rule 6.1)",         check_migration_sequence),
    ("Migration .py API  (Core Rule 6.1)",          check_py_migration_api),
    ("Schema.sql sync    (Core Rule 6.1)",          check_schema_sql_sync),
    ("No ad-hoc CREATE TABLE (Core Rule 6.1)",      check_no_adhoc_create),
]
TIER_2: list[tuple[str, object]] = [
    ("FSM tests — state machine invariants",      check_fsm_tests),
    ("Test collection — no syntax/import errors", check_test_collection),
]


def run_tier(checks: list, tier_name: str) -> int:
    sect(tier_name)
    failures = 0
    for name, fn in checks:
        t0 = time.time()
        passed, detail = fn()
        elapsed = time.time() - t0
        if passed:
            ok(f"{name}  {D(f'{elapsed:.1f}s')}")
            if detail and "skip" not in detail.lower():
                print(f"    {D(detail)}")
        else:
            fail(f"{name}  {D(f'{elapsed:.1f}s')}")
            for line in detail.splitlines():
                print(f"  {R('|')} {line}")
            failures += 1
    return failures


def list_rules() -> None:
    cov_file = REPO / "data" / "coverage_map.json"
    if not cov_file.exists():
        info("Coverage map not found — run ms-coverage first")
        return
    data = json.loads(cov_file.read_text())
    rules = [n for n in data["nodes"] if n["kind"] == "rule"]
    print(f"\n  {B('Active Core Rules')} ({len(rules)} total)\n")
    for rule in sorted(rules, key=lambda x: x["risk"] != "critical"):
        cov = G(chr(10003)) if rule["covered"] else R(chr(10007))
        risk_fn = R if rule["risk"] == "critical" else Y if rule["risk"] == "high" else D
        print(f"  {cov} [{risk_fn(rule['risk'][:4])}] {rule['label'][:65]}")


def main() -> None:
    args = sys.argv[1:]
    fast = "--fast" in args

    if "--list" in args:
        list_rules()
        return

    header("Mediastack Core Rules Enforcer")
    t_start = time.time()
    failures = 0

    failures += run_tier(TIER_0, "Tier 0 — Architectural Integrity")
    if failures > 0:
        print(f"\n  {_SEP}")
        print(f"  {R(chr(10007))} Blocked on Tier 0 — fix architectural violations first")
        print(f"  {D('ms-semgrep --verify   ms-coverage --section rule')}")
        print()
        sys.exit(1)

    failures += run_tier(TIER_1, "Tier 1 — Contract & Quality")
    if not fast:
        failures += run_tier(TIER_2, "Tier 2 — Behavioral Tests")

    elapsed = time.time() - t_start
    print(f"\n  {_SEP}")
    if failures == 0:
        print(f"  {G(chr(10003))}  All Core Rules satisfied  {D(f'{elapsed:.0f}s')}")
    else:
        print(f"  {R(chr(10007))}  {failures} rule(s) violated  {D(f'{elapsed:.0f}s')}")
    print()
    sys.exit(0 if failures == 0 else 1)


if __name__ == "__main__":
    main()