#!/usr/bin/env python3
"""ms-enforce — Core Rules Compliance Oracle

Runs every enforcement layer in dependency order. Fails on any violation.

  Tier 0 (instant): Semgrep + coverage rule gaps
  Tier 1 (~15s):    Path contracts + Catalog + Ruff + Bandit
  Tier 2 (~30s):    FSM tests + test collection

Usage:
  ms-enforce           # full (Tier 0+1+2)
  ms-enforce --fast    # Tier 0+1 only (pre-commit)
  ms-enforce --list    # show all rules

Install: sudo ln -sf /srv/mediastack/ms-enforce /usr/local/bin/ms-enforce
"""
from __future__ import annotations

import ast
import json
import re
import subprocess
import sys
import time
from pathlib import Path

REPO = Path(__file__).resolve().parent

_RESET = "\033[0m"
_BOLD = "\033[1m"
_DIM = "\033[2m"
_GREEN = "\033[0;32m"
_YELLOW = "\033[1;33m"
_RED = "\033[0;31m"
_CYAN = "\033[0;36m"


def G(s: str) -> str: return f"{_GREEN}{s}{_RESET}"
def R(s: str) -> str: return f"{_RED}{s}{_RESET}"
def Y(s: str) -> str: return f"{_YELLOW}{s}{_RESET}"
def D(s: str) -> str: return f"{_DIM}{s}{_RESET}"
def B(s: str) -> str: return f"{_BOLD}{s}{_RESET}"
def C(s: str) -> str: return f"{_CYAN}{s}{_RESET}"


def ok(msg: str)   -> None: print(f"  {G(chr(10003))} {msg}")
def fail(msg: str) -> None: print(f"  {R(chr(10007))} {msg}")
def info(msg: str) -> None: print(f"  {C(chr(8594))} {msg}")


_SEP = chr(9472) * 60


def header(title: str) -> None:
    ts = time.strftime("%H:%M  %Y-%m-%d")
    print(f"\n  {_SEP}\n  {title}  {D(ts)}\n  {_SEP}")


def sect(title: str) -> None:
    print(f"\n  {B(title)}")


def _run(cmd: list[str], timeout: int = 60) -> tuple[int, str]:
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, cwd=str(REPO), timeout=timeout)
        return r.returncode, r.stdout + r.stderr
    except subprocess.TimeoutExpired:
        return 1, f"timeout after {timeout}s"
    except Exception as exc:
        return 1, str(exc)


def _pytest_cmd() -> list[str]:
    """Pytest invocation prefix that resolves the project venv when present.

    Several runtime test deps (structlog, syrupy, pytest-asyncio) live in
    .venv only — system python lacks them, so subprocess invocations of
    `python3 -m pytest` fail at conftest import time on any host that
    doesn't happen to have those deps system-wide. Mirrors the same
    venv-detection pattern check_mypy uses (added in step 1.2.g, commit
    b94e9fe). Falls back to `python3` for minimal CI environments where
    the venv isn't built yet — those callers will still surface the real
    test results when deps are reachable.
    """
    venv_py = REPO / ".venv" / "bin" / "python3"
    if venv_py.exists():
        return [str(venv_py), "-m", "pytest"]
    return ["python3", "-m", "pytest"]


def _bad_lines(out: str, *markers: str) -> list[str]:
    return [x for x in out.splitlines() if any(m in x for m in markers)][:3]


# ── Tier 0 ────────────────────────────────────────────────────────────────

def check_semgrep() -> tuple[bool, str]:
    rules_dir = REPO / ".semgrep" / "rules"
    if not rules_dir.exists():
        return True, "semgrep rules not found (skip)"
    _, out = _run(["semgrep", "--config", str(rules_dir),
                   "backend/", "ms-testgen", "ms-coverage", "ms-test.py",
                   "--json", "--quiet", "--no-git-ignore"])
    try:
        data = json.loads(out.splitlines()[0] if "\n" in out else out)
        errors = [r for r in data.get("results", [])
                  if r.get("extra", {}).get("severity") == "ERROR"]
        if errors:
            detail = "\n".join(
                f"    {e['path']}:{e['start']['line']} "
                f"[{e['extra'].get('metadata',{}).get('core_rule','?')}] "
                f"{e['extra']['message'][:70]}"
                for e in errors[:5])
            return False, f"{len(errors)} violation(s):\n{detail}"
        return True, "0 architectural violations"
    except Exception:
        return True, "semgrep not available (skip)"


def check_coverage_rules() -> tuple[bool, str]:
    cov_file = REPO / "data" / "coverage_map.json"
    _run(["python3", str(REPO / "ms-coverage"), "--json"], timeout=30)
    if not cov_file.exists():
        return True, "coverage map not found (skip)"
    data = json.loads(cov_file.read_text())
    rules = [n for n in data["nodes"] if n["kind"] == "rule"]
    critical = [n for n in rules if not n["covered"] and n["risk"] == "critical"]
    high = [n for n in rules if not n["covered"] and n["risk"] == "high"]
    if critical:
        detail = "\n".join(f"    [critical] {n['label']}" for n in critical[:5])
        return False, f"{len(critical)} critical rule(s) uncovered:\n{detail}"
    if high:
        detail = "\n".join(f"    [high] {n['label']}" for n in high[:3])
        return False, f"{len(high)} high rule(s) uncovered:\n{detail}"
    return True, f"{len(rules)}/{len(rules)} architectural rules covered"


# ── Tier 1 ────────────────────────────────────────────────────────────────

def _pytest_check(test_id: str, label: str, timeout: int = 30) -> tuple[bool, str]:
    _, out = _run([*_pytest_cmd(), test_id, "-q", "--tb=short", "--no-header"],
                  timeout=timeout)
    if "passed" in out and "failed" not in out:
        return True, label
    bad = _bad_lines(out, "FAILED", "AssertionError", "Error")
    return False, "failed:\n" + "\n".join(f"    {x}" for x in bad)


def check_path_contracts() -> tuple[bool, str]:
    return _pytest_check(
        "tests/test_comprehensive_contracts.py::TestPathContractAlignment",
        "test paths match production write paths")


def check_catalog_compliance() -> tuple[bool, str]:
    return _pytest_check(
        "tests/test_non_catalog_installs.py::TestCatalogCompliance",
        "all catalog apps compliant")


def check_ruff() -> tuple[bool, str]:
    # Block only on codes that cause runtime crashes:
    #   F821 = undefined name (NameError at runtime)
    #   E999 = syntax error (won't import at all)
    # Style, convention, and bugbear codes are handled by the pre-commit
    # hook separately and don't block the architectural compliance check.
    _, out = _run(["python3", "-m", "ruff", "check", "backend/", "backend/scripts/",
                   "--select", "F821,E999,C901", "--output-format=json"])
    try:
        results = json.loads(out) if out.strip().startswith("[") else []
        if results:
            s = results[0]
            return False, (f"{len(results)} crash-risk error(s) — "
                           f"{s['filename'].split('/')[-1]}:{s['location']['row']} "
                           f"[{s['code']}] {s['message'][:60]}")
        return True, "0 undefined names or syntax errors"
    except Exception:
        return True, "ruff not available (skip)"


def check_mypy() -> tuple[bool, str]:
    """Run mypy --strict on backend/ per project mypy.ini (Core Rule 5.20).

    Uses .venv/bin/python3 — mypy is installed in the project venv only
    (system python lacks it; ruff/bandit happen to be installed system-wide
    as a separate ops decision). Skips gracefully if no venv is present
    (e.g., minimal CI environments) — matches the ruff/bandit fallback pattern.
    """
    venv_py = REPO / ".venv" / "bin" / "python3"
    if not venv_py.exists():
        return True, "venv not found (skip)"
    rc, out = _run(
        [str(venv_py), "-m", "mypy", "backend/", "--config-file", str(REPO / "mypy.ini")],
        timeout=120,
    )
    if rc == 0:
        last = out.strip().splitlines()[-1] if out.strip() else "no output"
        return True, last
    errors = [ln for ln in out.splitlines() if ": error:" in ln][:5]
    detail = "\n".join(f"    {ln}" for ln in errors)
    total = sum(1 for ln in out.splitlines() if ": error:" in ln)
    return False, f"{total} mypy error(s):\n{detail}"


def check_bandit() -> tuple[bool, str]:
    _, out = _run(["python3", "-m", "bandit", "-r", "backend/", "-f", "json", "-ll", "-ii"])
    try:
        data = json.loads(out) if out.strip().startswith("{") else {"results": []}
        high = [r for r in data.get("results", [])
                if r.get("issue_severity") in ("HIGH", "CRITICAL")
                and r.get("issue_confidence") == "HIGH"]
        if high:
            s = high[0]
            return False, (f"{len(high)} high-severity issue(s) — "
                           f"{s['filename']}:{s['line_number']} [{s['test_id']}]")
        return True, "0 high-severity security issues"
    except Exception:
        return True, "bandit not available (skip)"


def check_ownership() -> tuple[bool, str]:
    """All project files owned by the service user.

    sudo-invoked tools (ms-update, deploy.sh) can leave root-owned files in
    the working tree; this check fails fast so the issue is caught at commit
    time rather than two days later when an editor save mysteriously fails.
    Run `sudo tools/normalize-ownership.sh` to fix.
    """
    script = REPO / "tools" / "normalize-ownership.sh"
    if not script.exists():
        return True, "normalize-ownership.sh not found (skip)"
    rc, out = _run(["bash", str(script), "--check"], timeout=30)
    if rc == 0:
        # Script prints "All files owned by user:group" on success.
        last = out.strip().splitlines()[-1] if out.strip() else "ok"
        return True, last.strip().lstrip("✓ ").strip()
    # rc=1 means wrong ownership found. The script prints the offenders.
    bad = [ln.strip() for ln in out.splitlines()
           if ln.strip() and not ln.strip().startswith(("→", "✗", "..."))][:3]
    detail = "\n".join(f"    {ln}" for ln in bad)
    return False, f"wrong ownership found:\n{detail}\n    fix: sudo {script}"




