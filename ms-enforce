def check_referenced_files() -> tuple[bool, str]:
    """Tier 1: orphan/doc-audit check (S-48-TRACK-GATE Stream B + S-56 Stream C).

    Runs ``tools/check_referenced_files.py`` which performs four checks:
    1. Generic orphan detection — tracked files with zero inbound refs > 30 days.
    2. Broken Markdown links in docs/ — [text](path) or `path` pointing to
       non-existent files.
    3. Doc orphans — tracked .md files in docs/ with zero inbound refs > 30 days.
    4. Doc MAP coverage — tracked docs/ .md files absent from docs/MAP.md.

    Always returns True (warning-only, never blocking).  Categories are tagged
    in the WARNING lines as ``[doc-broken-link]``, ``[doc-orphan]``,
    ``[doc-missing-from-MAP]``, or generic orphan warnings.
    """
    script = REPO / "tools" / "check_referenced_files.py"
    if not script.exists():
        return True, "orphan-file script not present (skip)"
    _rc, out = _run(["python3", str(script)], timeout=120)
    # Always True — this check is warning-only.
    all_warnings = [line for line in out.splitlines() if line.startswith("WARNING")]
    if not all_warnings:
        return True, "no issues detected (orphans, broken links, MAP coverage all clean)"

    # Categorise for a structured summary.
    orphans = [w for w in all_warnings if "orphan file" in w and "[doc-" not in w]
    broken_links = [w for w in all_warnings if "[doc-broken-link]" in w]
    doc_orphans = [w for w in all_warnings if "[doc-orphan]" in w]
    map_missing = [w for w in all_warnings if "[doc-missing-from-MAP]" in w]

    parts: list[str] = []
    if orphans:
        parts.append(f"  {len(orphans)} generic orphan file(s):")
        for w in orphans[:3]:
            parts.append(f"    {w}")
        if len(orphans) > 3:
            parts.append(f"    ... and {len(orphans) - 3} more")
    if broken_links:
        parts.append(f"  {len(broken_links)} broken doc link(s):")
        for w in broken_links[:3]:
            parts.append(f"    {w}")
        if len(broken_links) > 3:
            parts.append(f"    ... and {len(broken_links) - 3} more")
    if doc_orphans:
        parts.append(f"  {len(doc_orphans)} doc orphan(s):")
        for w in doc_orphans[:3]:
            parts.append(f"    {w}")
        if len(doc_orphans) > 3:
            parts.append(f"    ... and {len(doc_orphans) - 3} more")
    if map_missing:
        parts.append(f"  {len(map_missing)} doc(s) missing from MAP.md:")
        for w in map_missing[:3]:
            parts.append(f"    {w}")
        if len(map_missing) > 3:
            parts.append(f"    ... and {len(map_missing) - 3} more")

    total = len(all_warnings)
    summary = f"{total} total warning(s) (all warn-only):\n" + "\n".join(parts)
    return True, summary


def check_test_isolation() -> tuple[bool, str]:
    """Tier 1 (S-71 Stream C): test-data-isolation gate — warn-only.

    Runs ``tools/check_test_isolation.py``, a conservative AST heuristic that
