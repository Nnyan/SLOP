def check_fsm_tests() -> tuple[bool, str]:
    rc, out = _run([
        *_pytest_cmd(),
        "tests/test_fsm_app_install.py",
        "tests/test_fsm_platform.py",
        "tests/test_fsm_health_check.py",
        "-q", "--tb=short", "--no-header",
