def check_precondition_declarations() -> tuple[bool, str]:
    """Core Rule 2.9: tests declare preconditions via section_requires()."""
    ms_test = REPO / 'ms-test.py'
    if not ms_test.exists():
        return True, 'ms-test.py not found (skip)'
    src = ms_test.read_text()
    if '_populate_context' not in src:
        return False, 'ms-test.py missing _populate_context() — precondition system not installed'
    if 'section_requires' not in src:
        return False, 'ms-test.py missing section_requires() — precondition guard not installed'
    if '_populate_context()  # Core Rule 2.9' not in src:
        return False, '_populate_context() not called in main() — preconditions never set'
    if 'section_requires("platform_status"' not in src:
        return False, 'Q3 must use section_requires(platform_status) not bare if/else'
    _, out = _run([
        *_pytest_cmd(),
        'tests/test_comprehensive_contracts.py::TestQ3ComposeFragmentInvariant',
        '-q', '--tb=short', '--no-header',
    ], timeout=30)
    if 'passed' in out and 'failed' not in out:
        return True, 'precondition system present and Q3 invariant verified'
    bad = [x for x in out.splitlines() if 'FAILED' in x or 'Error' in x][:3]
    return False, 'precondition test failed: ' + ' | '.join(bad)


def check_shellcheck() -> tuple[bool, str]:
    """ShellCheck: structural shell script bugs (bad substitutions, unquoted vars)."""
    import subprocess as _sp
    if _sp.run(["which", "shellcheck"], capture_output=True).returncode != 0:
        return True, "shellcheck not installed (sudo apt-get install shellcheck)"
    shell_scripts = ["ms-check", "ms-update", "ms-test-all", "ms-setup-tools"]
    errors = []
    for script in shell_scripts:
        p = REPO / script
        if not p.exists(): continue
        r = _sp.run(["shellcheck", "-S", "error", str(p)],
                    capture_output=True, text=True, cwd=str(REPO))
        if r.returncode != 0:
            for line in r.stdout.splitlines():
                if "SC" in line and "error" in line.lower():
                    errors.append(f"{script}: {line.strip()[:80]}")
    if errors:
        detail = "\n".join(f"    {e}" for e in errors[:5])
        return False, f"{len(errors)} shell error(s):\n{detail}"
    return True, f"{len(shell_scripts)} shell scripts clean"


def check_heredoc_python() -> tuple[bool, str]:
    """Python in shell heredocs is invisible to Ruff/Semgrep/Bandit — must be extracted."""
    import re
    violations = []
    for script in REPO.glob("ms-*"):
        if not script.is_file(): continue
        try:
            content = script.read_text()
        except Exception:
            continue
        matches = re.findall(r"python3.*<<.*?'([A-Z_]+)'\n(.*?)\n\1", content, re.DOTALL)
        for _, py_content in matches:
            py_lines = len([l for l in py_content.splitlines() if l.strip()])
            if py_lines > 20:
                violations.append(f"{script.name}: {py_lines} Python lines in heredoc")
    if violations:
        return False, "Python heredocs >20 lines (invisible to tools): " + " | ".join(violations)
    return True, "no large Python heredocs in shell scripts"


