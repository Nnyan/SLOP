def check_logging_discipline() -> tuple[bool, str]:
    """Tier 2 (Core Rule 4.13): backend code logs through structlog.

    AST-walks `backend/` and reports:
      - `print(` calls (should be structured `log.info` / etc.)
      - `logging.info(`, `logging.warning(`, `logging.error(`, `logging.debug(`
        called as module-level functions (should be `log.X` from a
        `get_logger` instance)
      - `log = logging.getLogger(...)` module-level binding (should be
        `log = get_logger(__name__)` from `backend.core.logging`)

    MANDATORY (returns False on any finding) since step 2.3.e completed
    the sweep and the count is zero. Exclusions per strategy doc §11:
    `backend/core/logging.py` (the configurer) and `backend/scripts/`
    (operator-facing CLI; their print() output is the UX, pinned by
    snapshot tests under Rule 4.11).
    """
    # Exclusions per strategy doc §11:
    #   - backend/core/logging.py is THE configurer of the stdlib bridge —
    #     it must use stdlib logging directly.
    #   - backend/scripts/ are operator-facing CLI scripts; their print()
    #     calls are intentional UX output, not service logs (their output
    #     format is pinned by snapshot tests under Rule 4.11).
    excluded_files = {
        "backend/core/logging.py",
        # backend/agent/router/cli.py is an operator-facing CLI
        # (`python -m backend.agent.router status`); its print() output is the
        # UX, same rationale as backend/scripts/ below (S-62-MS-ROUTER).
        "backend/agent/router/cli.py",
    }
    excluded_prefixes = ("backend/scripts/",)
    print_calls = 0
    logging_calls = 0
    legacy_loggers = 0
    smelly_files: set[str] = set()
    backend_dir = REPO / "backend"
    for path in sorted(backend_dir.rglob("*.py")):
        rel = str(path.relative_to(REPO))
        if rel in excluded_files:
            continue
        if any(rel.startswith(p) for p in excluded_prefixes):
            continue
        try:
            tree = ast.parse(path.read_text())
        except SyntaxError:
            continue
        file_smelly = False
        for node in ast.walk(tree):
            # `print(...)` calls
            if (isinstance(node, ast.Call)
                    and isinstance(node.func, ast.Name)
                    and node.func.id == "print"):
                print_calls += 1
                file_smelly = True
            # `logging.info(...)` / `.warning(...)` / `.error(...)` / `.debug(...)`
            if (isinstance(node, ast.Call)
                    and isinstance(node.func, ast.Attribute)
                    and isinstance(node.func.value, ast.Name)
                    and node.func.value.id == "logging"
                    and node.func.attr in ("info", "warning", "error",
                                            "debug", "critical")):
                logging_calls += 1
                file_smelly = True
            # `logging.getLogger(...)` at the module level
            if (isinstance(node, ast.Call)
                    and isinstance(node.func, ast.Attribute)
                    and isinstance(node.func.value, ast.Name)
                    and node.func.value.id == "logging"
                    and node.func.attr == "getLogger"):
                legacy_loggers += 1
                file_smelly = True
        if file_smelly:
            smelly_files.add(rel)
    total = print_calls + logging_calls + legacy_loggers
    if total == 0:
        return True, "all backend/ logs route through structlog"
    msg = (
        f"{total} ad-hoc logging site(s) in {len(smelly_files)} file(s) "
        f"— migrate to `from backend.core.logging import get_logger`:\n"
        f"  print(...) calls:           {print_calls}\n"
        f"  logging.{{info,warn,...}}:  {logging_calls}\n"
        f"  logging.getLogger(...):     {legacy_loggers}"
    )
    return False, msg


def check_mock_discipline() -> tuple[bool, str]:
    """Tier 2 (Core Rule 4.12): warn on tests with too many internal mocks.

    Counts `@patch("backend.X")` decorators stacked on a single test
    function. > 3 internal mocks signals possible over-mocking — the
    test may be asserting on mock-call-graphs rather than behaviour.

    Returns (True, message) always — informational, not blocking. Real
    fakes (tmp_path-backed FS, fresh in-memory StateDB, real test
    manifests) are preferred per docs/adr/0002-mocking-policy.md.
    """
    threshold = 3
    smelly: list[str] = []
    test_dir = REPO / "tests"
    for path in sorted(test_dir.rglob("test_*.py")):
        try:
            tree = ast.parse(path.read_text())
        except SyntaxError:
            continue
        for node in ast.walk(tree):
            if not isinstance(node, ast.FunctionDef):
                continue
            if not node.name.startswith("test_"):
                continue
            internal = 0
            for deco in node.decorator_list:
                # Match `@patch("backend.X.Y")` decorators
                if (isinstance(deco, ast.Call)
                        and isinstance(deco.func, ast.Name)
                        and deco.func.id == "patch"
                        and deco.args
                        and isinstance(deco.args[0], ast.Constant)
                        and isinstance(deco.args[0].value, str)
                        and deco.args[0].value.startswith("backend.")):
                    internal += 1
            if internal > threshold:
                rel = path.relative_to(REPO)
                smelly.append(
                    f"{rel}::{node.name}  ({internal} internal mocks at line {node.lineno})"
                )
    msg = (
        f"{len(smelly)} test(s) stack more than {threshold} internal mocks "
        f"(boundary mocks are fine; see docs/adr/0002-mocking-policy.md)"
    )
    if smelly:
        msg += ":\n  " + "\n  ".join(smelly[:5])
        if len(smelly) > 5:
            msg += f"\n  … and {len(smelly) - 5} more"
    # Always return True — this is a warning, not a block
    return True, msg


def check_dead_code() -> tuple[bool, str]:
    """Tier 2 (Core Rule 4.17): warn on unused functions / variables / classes.

    Runs vulture (configured via pyproject.toml `[tool.vulture]`) at
    its default 80% confidence threshold. The whitelist covers
    decorator-registered handlers (FastAPI / pytest / register), so
    findings here represent likely-real dead code that the team
    should review.

    Heuristic — returns True (warning, not block). False positives
    are real with vulture; gating on it would block too aggressively.
    Add survivors to `[tool.vulture].ignore_names` in pyproject.toml
    or remove them.
    """
    try:
        result = subprocess.run(
            [sys.executable, "-m", "vulture"],
            capture_output=True, text=True, cwd=str(REPO), timeout=60,
        )
    except FileNotFoundError:
        return True, "vulture not installed (pip install vulture) — skipping"
    except subprocess.TimeoutExpired:
        return True, "vulture timed out after 60s — skipping"
    output = (result.stdout or "").strip()
    if not output:
        return True, "no findings at 80% confidence"
    findings = output.splitlines()
    msg = (
        f"{len(findings)} likely-dead item(s) "
        "(heuristic — review, don't auto-remove)"
    )
    msg += ":\n  " + "\n  ".join(findings[:5])
    if len(findings) > 5:
        msg += f"\n  … and {len(findings) - 5} more"
    return True, msg  # warning, not blocking


def check_adr_present_for_breaking_change() -> tuple[bool, str]:
    """Tier 2 (Core Rule 4.15 / ADR discipline): warn when staged
    changes look like a breaking change but no ADR is referenced.

    Heuristic — returns True (warning, not block). False positives are
    real (a typo fix in a schema migration shouldn't require a new
    ADR). The check just nudges the operator to consider whether an
    ADR is warranted.

    Signals scanned in the staged diff (`git diff --cached`):

      1. New file under `migrations/` (schema change).
      2. Removed `@router.<method>(...)` decorator (route deletion).
      3. New API surface — added `@router.delete(...)` or `@router.put(...)`.
      4. ADR file added in the same diff is the silencer — when an
         ADR mod/add appears, no warning regardless of the other
         signals.

    The check parses the staged diff via `git`. If git is unavailable
    or no changes are staged, returns "no staged changes — skipping"
    (still a pass).
    """
    try:
        diff = subprocess.run(
            ["git", "diff", "--cached", "--name-status"],
            capture_output=True, text=True, cwd=str(REPO), timeout=10,
            check=True,
        ).stdout
    except (subprocess.SubprocessError, FileNotFoundError):
        return True, "git unavailable — skipping"

    if not diff.strip():
        return True, "no staged changes — skipping"

    files: list[tuple[str, str]] = []
    for line in diff.splitlines():
        parts = line.split("\t", 1)
        if len(parts) == 2:
            files.append((parts[0].strip(), parts[1].strip()))

    # An ADR add/modify silences the warning.
    if any(f.startswith("docs/adr/") and f.endswith(".md") for _s, f in files):
        return True, "ADR present in staged diff — no warning"

    signals: list[str] = []

    # Signal 1: new migration file
    for s, f in files:
        if s.startswith("A") and f.startswith("migrations/") and f.endswith((".sql", ".py")):
            signals.append(f"new migration: {f}")

    # Signals 2 + 3: route additions / removals in api/*.py
    diff_full = subprocess.run(
        ["git", "diff", "--cached", "--", "backend/api/"],
        capture_output=True, text=True, cwd=str(REPO), timeout=10,
    ).stdout
    for line in diff_full.splitlines():
        if line.startswith("-") and not line.startswith("---"):
            if re.search(r"@router\.(get|post|put|delete|patch)\(", line):
                signals.append("route decorator removed")
                break
    for line in diff_full.splitlines():
        if line.startswith("+") and not line.startswith("+++"):
            if re.search(r"@router\.(delete|put)\(", line):
                signals.append("new mutating route added (delete/put)")
                break

    if not signals:
        return True, "no breaking-change signals in staged diff"

    msg = (
        f"{len(signals)} breaking-change signal(s) staged without an ADR:\n  "
        + "\n  ".join(signals[:5])
        + "\n  Consider whether this change warrants an ADR in docs/adr/."
    )
    return True, msg  # warning, not blocking


def check_llm_outbound_scrubbed() -> tuple[bool, str]:
    """ADR 0018: cloud-bound LLM calls must pass through scrub() before dispatch.

    Verifies that backend/health/checker.py::_dispatch_llm_call routes text
    destined for cloud providers through scrub() before the HTTP call.
    Fails if the scrub import or the scrub() call-site is absent.

    NOTE: this check is expected to FAIL until Stream C (S-61) wires scrub()
    into _dispatch_llm_call.  A clean violation message is correct; a Python
    traceback inside this function is a bug in the check itself.
    """
    checker = REPO / "backend" / "health" / "checker.py"
    if not checker.exists():
        return False, "backend/health/checker.py not found"

    src = checker.read_text(encoding="utf-8")

    # 1. The function _dispatch_llm_call must exist
    if "_dispatch_llm_call" not in src:
        return False, "backend/health/checker.py: _dispatch_llm_call not found"

    # 2. scrub must be imported
    has_import = (
        "from backend.agent.scrub import scrub" in src
        or "from backend.agent import scrub" in src
        or "import scrub" in src
    )
    if not has_import:
        return (
            False,
            "backend/health/checker.py: missing 'from backend.agent.scrub import scrub' "
            "— ADR-0018 requires scrub() to be imported before use on cloud path",
        )

    # 3. scrub() must be called somewhere in the function body — locate the
    #    function via AST and check for a scrub() call within it.
    try:
        tree = ast.parse(src, filename=str(checker))
    except SyntaxError as exc:
        return False, f"backend/health/checker.py: SyntaxError — {exc}"

    dispatch_fn: ast.AsyncFunctionDef | ast.FunctionDef | None = None
    for node in ast.walk(tree):
        if isinstance(node, (ast.AsyncFunctionDef, ast.FunctionDef)):
            if node.name == "_dispatch_llm_call":
                dispatch_fn = node
                break

    if dispatch_fn is None:
        return False, "backend/health/checker.py: _dispatch_llm_call AST node not found"

    # Walk the function body for a Call to scrub(...)
    scrub_called = False
    for node in ast.walk(dispatch_fn):
        if isinstance(node, ast.Call):
            func = node.func
            if isinstance(func, ast.Name) and func.id == "scrub":
                scrub_called = True
                break
            if isinstance(func, ast.Attribute) and func.attr == "scrub":
                scrub_called = True
                break

    if not scrub_called:
        return (
            False,
            "backend/health/checker.py::_dispatch_llm_call does not call scrub() "
            "on the cloud path — ADR-0018 violation; wire Stream C to fix",
        )

    return True, "_dispatch_llm_call routes cloud text through scrub() (ADR-0018 satisfied)"


def check_walkback_log() -> tuple[bool, str]:
    """Tier 1: WALK-BACK-LOG reference required on substantive doctrine removals.

    Looks at HEAD: if it modifies .claude/ROBOT.md, .claude/AUTONOMOUS-DEFAULTS.md,
    or CLAUDE.md AND removes >=3 lines from the file, the commit message must
    reference docs/WALK-BACK-LOG.md (or the file `WALK-BACK-LOG` by substring).

    Warn-only: returns (True, summary). Graduates to fail when the aging-policy
    mechanism (planned S-70) ships and explicitly escalates this check.

    Rationale: every doctrine rule encodes a NEED; removing the rule without
    addressing the underlying need leaves the need orphaned. The walk-back log
    captures the meta-thinking (what was the rule preventing; new mechanism;
    failure mode). See docs/WALK-BACK-LOG.md.
    """
    doctrine_files = {
        ".claude/ROBOT.md",
        ".claude/AUTONOMOUS-DEFAULTS.md",
        "CLAUDE.md",
    }
    # Get HEAD commit message + files-changed numstat in one git call.
    rc, msg = _run(["git", "log", "-1", "--format=%B"], timeout=5)
    if rc != 0:
        return True, "git log unavailable (skip)"
    commit_msg = msg

    rc, numstat = _run(["git", "log", "-1", "--numstat", "--format="], timeout=5)
    if rc != 0:
        return True, "git numstat unavailable (skip)"

    flagged: list[tuple[str, int]] = []
    for line in numstat.splitlines():
        line = line.strip()
        if not line:
            continue
        parts = line.split("\t")
        if len(parts) != 3:
            continue
        added_s, deleted_s, path = parts
        if path not in doctrine_files:
            continue
        try:
            deleted = int(deleted_s)
        except ValueError:
            continue
        if deleted >= 3:
            flagged.append((path, deleted))

    if not flagged:
        return True, "no substantive doctrine removals on HEAD (no walk-back log reference required)"

    msg_lower = commit_msg.lower()
    if "walk-back-log" in msg_lower or "walk_back_log" in msg_lower or "walkback" in msg_lower:
        return True, f"doctrine removals on HEAD reference walk-back log ({len(flagged)} file(s))"

    summary = (
        f"WARNING: HEAD removes >=3 lines from doctrine file(s) without referencing "
        f"docs/WALK-BACK-LOG.md in commit message:\n"
    )
    for path, deleted in flagged:
        summary += f"    {path}: -{deleted} lines\n"
    summary += (
        "    Add a WALK-BACK-LOG entry answering: what the rule was preventing, "
        "why walked back, new mechanism for the underlying need, failure mode "
        "of the new mechanism. See docs/WALK-BACK-LOG.md for format."
    )
    return True, summary  # warn-only: True means pass


