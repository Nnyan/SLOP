_ADR_ENFORCEMENT_ANNOTATION_RE = re.compile(
    r"^>\s*Enforcement:\s*\[(?:manual|automated)\s+—",
    re.MULTILINE,
)


def check_adr_enforcement() -> tuple[bool, str]:
    """Every accepted ADR is accounted for by ONE of:
      (a) its ADR number appears in ms-enforce or ms-coverage (check label,
          RULES[] rationale, or explicit mapping comment), OR
      (b) the ADR file itself carries an annotation line of the form
          '> Enforcement: [manual — <rationale>]' or
          '> Enforcement: [automated — <check name>]'.

    The annotation form lets architectural decisions that are not machine-checkable
    (or that are checked outside ms-enforce, e.g., installer-only tests) declare
    their enforcement story durably in the ADR file rather than via a stub check.
    """
    adr_dir = REPO / "docs" / "adr"
    if not adr_dir.exists():
        return True, "no docs/adr/ directory — skip"

    enforce_text = (REPO / "ms-enforce").read_text()
    coverage_text = (REPO / "ms-coverage").read_text()

    unmatched: list[str] = []
    for path in sorted(adr_dir.glob("*.md")):
        m = re.match(r"^(\d{4})-", path.name)
        if not m:
            continue
        content = path.read_text()
        if "Status: Accepted" not in content and "**Status:** Accepted" not in content:
            continue
        num = m.group(1)  # e.g. "0012"
        if _ADR_ENFORCEMENT_ANNOTATION_RE.search(content):
            continue  # ADR declares its own enforcement story
        if num not in enforce_text and num not in coverage_text:
            unmatched.append(f"ADR {num} ({path.name}) — no matching check label or RULES entry")

    if unmatched:
        detail = "\n".join(unmatched)
        return True, f"{len(unmatched)} accepted ADR(s) lack automated enforcement coverage:\n{detail}"
    return True, "all accepted ADRs have enforcement coverage"



# ── Migration checks (Core Rule 5.19 / 6.1) ──────────────────────────────

_MIGRATION_NAME_RE = re.compile(r"^(\d{3})_[a-z0-9_]+\.(sql|py)$")

# Files where CREATE TABLE IF NOT EXISTS is permitted
_ALLOWED_CREATE_TABLE = {
    REPO / "backend" / "core" / "schema.sql",
    REPO / "backend" / "core" / "migrations.py",   # schema_migrations bootstrap only
}
_ALLOWED_CREATE_TABLE_DIRS = {REPO / "migrations"}
# Known legacy files scheduled for cleanup (§9 of design doc)
_LEGACY_CREATE_TABLE = {
    REPO / "backend" / "api" / "health.py",
    REPO / "backend" / "api" / "models.py",
    REPO / "backend" / "health" / "checker.py",
    REPO / "backend" / "health" / "source_checker.py",
    REPO / "backend" / "health" / "managed_services.py",
    REPO / "backend" / "api" / "quickstart.py",
}


def check_migration_sequence() -> tuple[bool, str]:
    """Core Rule 6.1: migration version numbers are strictly monotonic (no gaps, no duplicates)."""
    mig_dir = REPO / "migrations"
    if not mig_dir.exists():
        return False, "migrations/ directory not found"
    files: list[tuple[int, str]] = []
    for p in mig_dir.iterdir():
        if p.is_dir():
            continue
        m = _MIGRATION_NAME_RE.match(p.name)
        if m:
            files.append((int(m.group(1)), p.name))
    if not files:
        return False, "no migration files found in migrations/"
    files.sort()
    seen: dict[int, str] = {}
    issues: list[str] = []
    for version, name in files:
        if version in seen:
            issues.append(f"duplicate version {version:03d}: {seen[version]} and {name}")
        seen[version] = name
    versions = sorted(v for v, _ in files)
    for i in range(1, len(versions)):
        if versions[i] != versions[i - 1] + 1:
            issues.append(
                f"gap: {versions[i - 1]:03d} → {versions[i]:03d} "
                f"(missing {versions[i - 1] + 1:03d})"
            )
    if issues:
        return False, "; ".join(issues)
    return True, f"{len(files)} migration(s), sequence {versions[0]:03d}–{versions[-1]:03d} clean"


def check_py_migration_api() -> tuple[bool, str]:
    """Core Rule 6.1: every .py migration exports def upgrade(conn)."""
    mig_dir = REPO / "migrations"
    if not mig_dir.exists():
        return True, "migrations/ not found (skip)"
    issues: list[str] = []
    for p in mig_dir.iterdir():
        if p.suffix != ".py" or not _MIGRATION_NAME_RE.match(p.name):
            continue
        try:
            tree = ast.parse(p.read_text(encoding="utf-8"), filename=str(p))
        except SyntaxError as e:
            issues.append(f"{p.name}: SyntaxError — {e}")
            continue
        top_fns = {
            node.name
            for node in ast.walk(tree)
            if isinstance(node, ast.FunctionDef) and node.col_offset == 0
        }
        if "upgrade" not in top_fns:
            issues.append(f"{p.name}: missing top-level def upgrade(conn)")
    if issues:
        return False, "; ".join(issues)
    checked = sum(1 for p in mig_dir.iterdir()
                  if p.suffix == ".py" and _MIGRATION_NAME_RE.match(p.name))
    return True, f"{checked} .py migration(s) expose upgrade(conn)"


def check_schema_sql_sync() -> tuple[bool, str]:
    """Core Rule 6.1: schema.sql matches what migrations/ would generate."""
    regen = REPO / "tools" / "regenerate-schema-sql.py"
    if not regen.exists():
        return False, "tools/regenerate-schema-sql.py not found — run step 1.1.d"
    rc, out = _run(["python3", str(regen), "--check"], timeout=30)
    if rc != 0:
        first_line = next((l for l in out.splitlines() if l.strip()), out[:120])
        return False, f"schema.sql out of sync — run: python3 tools/regenerate-schema-sql.py\n    {first_line}"
    return True, "schema.sql in sync with migrations/"


def check_no_adhoc_create() -> tuple[bool, str]:
    """Core Rule 6.1: no new CREATE TABLE IF NOT EXISTS outside migrations/ or schema.sql."""
    pattern = re.compile(r"CREATE\s+TABLE\s+IF\s+NOT\s+EXISTS", re.IGNORECASE)
    issues: list[str] = []
    for path in sorted((REPO / "backend").rglob("*.py")):
        if path in _ALLOWED_CREATE_TABLE or path in _LEGACY_CREATE_TABLE:
            continue
        if any(path.is_relative_to(d) for d in _ALLOWED_CREATE_TABLE_DIRS):
            continue
        try:
            text = path.read_text(encoding="utf-8", errors="replace")
        except OSError:
            continue
        for lineno, line in enumerate(text.splitlines(), 1):
            if pattern.search(line):
                rel = path.relative_to(REPO)
                issues.append(f"{rel}:{lineno} — schema changes go in migrations/ (Core Rule 6.1)")
    if issues:
        return False, "\n".join(f"    {i}" for i in issues[:5])
    return True, "no ad-hoc CREATE TABLE IF NOT EXISTS outside permitted files"


def check_file_size_ratchet() -> tuple[bool, str]:
    """Tier 1: file-size ratchet (wave S-45-RATCHET).

    Runs `tools/check_linecount.py` to enforce tiered caps on new files and
    the per-file baseline ceiling on existing oversize files. The baseline
    is committed at `.linecount-baseline.json`. Tests over 1000 lines print
    a WARNING but do NOT fail.
    """
    script = REPO / "tools" / "check_linecount.py"
    if not script.exists():
        return True, "ratchet script not present (skip)"
    rc, out = _run(["python3", str(script)], timeout=30)
    if rc == 0:
        warnings = [line for line in out.splitlines() if line.startswith("WARNING")]
        if warnings:
            return True, f"{len(warnings)} test file(s) over 1000 lines (informational)"
        return True, "all source files within tiered caps + baseline"
    bad = [line for line in out.splitlines() if line.strip()][:10]
    return False, "ratchet violations:\n" + "\n".join(f"    {line}" for line in bad)


def check_catalog_env_var_syntax() -> tuple[bool, str]:
    """Tier 1 (S-55-B): catalog env: blocks must use ${VAR} syntax, not Python {VAR}.

    Docker Compose interpolates ${VAR} at runtime. A bare {VAR} (Python f-string
    style) is silently left as a literal string by Docker Compose — the variable
    is never substituted. This is a high-blast-radius silent failure: the catalog
    YAML parses without error and the install appears to succeed, but the var
    resolves to the literal text '{VAR}' in the container environment.

    Scope: env: blocks only. Volume host: paths intentionally use {config_root}
    and {media_root} — handled by _expand_path() in executor.py.
    """
    try:
        import yaml as _yaml
    except ImportError:
        return True, "PyYAML not installed (skip)"

    bare_brace = re.compile(r"(?<!\$)\{[A-Z_][A-Z0-9_]*\}")
    violations: list[str] = []
    catalog_dir = REPO / "catalog" / "apps"
    if not catalog_dir.exists():
        return True, "catalog/apps/ not found (skip)"

    for yaml_path in sorted(catalog_dir.glob("*.yaml")):
        try:
            data = _yaml.safe_load(yaml_path.read_text(encoding="utf-8"))
        except Exception as exc:
            violations.append(f"{yaml_path.name}: YAML parse error — {exc}")
            continue
        if not isinstance(data, dict):
            continue
        env_block = data.get("env") or {}
        if not isinstance(env_block, dict):
            continue
        for var_name, value in env_block.items():
            if value is None:
                continue
            str_value = str(value)
            if bare_brace.search(str_value):
                violations.append(
                    f"{yaml_path.name}: env.{var_name}={str_value!r} "
                    "uses bare {{VAR}} — must be ${{VAR}} for Docker Compose interpolation"
                )

    if violations:
        detail = "\n".join(f"    {v}" for v in violations[:10])
        return False, f"{len(violations)} catalog env-var syntax violation(s):\n{detail}"
    checked = sum(1 for _ in catalog_dir.glob("*.yaml"))
    return True, f"{checked} catalog YAML env blocks use correct ${{VAR}} syntax"


def check_track_status() -> tuple[bool, str]:
