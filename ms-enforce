def check_backlog_coverage() -> tuple[bool, str]:
    """Tier 1: BACKLOG coverage audit (wave S-56-E) — warn-only.

    Runs three floating-work scanners:
      tools/audit_todos.py            — code TODO/FIXME/HACK/XXX markers
      tools/audit_archived_observations.py — archive files with future-work signals
      tools/audit_wave_out_of_scope.py     — wave out-of-scope bullets not in BACKLOG

    Exits 0 always (visibility, not blocking). Emits WARNING when any scanner
    finds items not referenced in docs/BACKLOG.md.
    """
    todo_script = REPO / "tools" / "audit_todos.py"
    obs_script  = REPO / "tools" / "audit_archived_observations.py"
    oos_script  = REPO / "tools" / "audit_wave_out_of_scope.py"

    venv_py = REPO / ".venv" / "bin" / "python3"
    py = str(venv_py) if venv_py.exists() else "python3"

    results = []
    total_untracked = 0

    for script, label in [
        (todo_script, "todos"),
        (obs_script,  "observations"),
        (oos_script,  "wave-oos"),
    ]:
        if not script.exists():
            results.append(f"    {label}: script not present (skip)")
            continue
        _rc, out = _run([py, str(script), "--repo", str(REPO)], timeout=60)
        lines = [ln for ln in out.splitlines() if ln.startswith("UNTRACKED") or ln.startswith("CANDIDATE")]
        total_untracked += len(lines)
        if lines:
            results.append(f"    {label}: {len(lines)} untracked item(s)")
            results.extend(f"      {ln[:100]}" for ln in lines[:3])
            if len(lines) > 3:
                results.append(f"      ... and {len(lines) - 3} more")
        else:
            results.append(f"    {label}: clean")

    detail = f"{total_untracked} total untracked item(s) across scanners:\n" + "\n".join(results)
    if total_untracked == 0:
        return True, "all floating-work scanners clean — BACKLOG.md is current"
    return True, f"WARNING — {detail}"  # always True — warn-only


