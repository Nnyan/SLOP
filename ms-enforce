def check_doc_reality() -> tuple[bool, str]:
    """Tier 1 (S-75-B): doc-vs-reality reconciler — warn-only.

    THIN wrapper: imports tools/audit_doc_reality.py and calls its run() with the
    host UNSET (no ambient SSH available inside ms-enforce), so every GROUND claim
    surfaces as INDETERMINATE here — loud, never OK. The real ground reconciliation
    happens at SessionStart via the operator's ambient SSH (Option A); see the
    wiring note at the top of tools/audit_doc_reality.py.

    Reconciles the documented deploy facts (CLAUDE.md + memory) against the PINNED
    RealityView emitted by slop-reality-probe. Only DRIFT on a load-bearing claim
    files to docs/BACKLOG.md (deduped); INCONSISTENT routes to .claude/run/
    xref-findings/ (does NOT count against BACKLOG triage); INDETERMINATE on an
    unreachable host is reported loudly and never written.

    Always returns True (warn-only). PROMOTION-TO-BLOCKING TRIGGER: promote only
    once (a) the host probe runs reliably for >=30 days with zero tooling-caused
    INDETERMINATE AND (b) a deploy-fact DRIFT has been caught + fixed at least once
    via this gate (proving it can go red against physics). Until both hold, warn-only.
    """
    tool = REPO / "tools" / "audit_doc_reality.py"
    if not tool.exists():
        return True, "tools/audit_doc_reality.py not present (skip)"
    import importlib.util
    spec = importlib.util.spec_from_file_location("audit_doc_reality", tool)
    if spec is None or spec.loader is None:
        return True, "audit_doc_reality.py not importable (skip)"
    mod = importlib.util.module_from_spec(spec)
    try:
        spec.loader.exec_module(mod)
        # host=None inside ms-enforce ⇒ INDETERMINATE (no ambient SSH here);
        # write_findings=False so the gate is pure visibility, never mutates docs.
        _ok, summary, _verdicts = mod.run(REPO, host=None, write_findings=False)
    except Exception as exc:  # noqa: BLE001 — never let warn-only gate raise
        return True, f"doc-vs-reality reconciler error (warn-only, skipped): {exc}"
    return True, summary  # always True — warn-only
