def run_tier(checks: list, tier_name: str) -> int:
    sect(tier_name)
    failures = 0
    for name, fn in checks:
        t0 = time.time()
        passed, detail = fn()
        elapsed = time.time() - t0
        if passed:
            ok(f"{name}  {D(f'{elapsed:.1f}s')}")
            if detail and "skip" not in detail.lower():
                print(f"    {D(detail)}")
        else:
            fail(f"{name}  {D(f'{elapsed:.1f}s')}")
            for line in detail.splitlines():
                print(f"  {R('|')} {line}")
            failures += 1
    return failures


def list_rules() -> None:
    cov_file = REPO / "data" / "coverage_map.json"
    if not cov_file.exists():
        info("Coverage map not found — run ms-coverage first")
        return
    data = json.loads(cov_file.read_text())
    rules = [n for n in data["nodes"] if n["kind"] == "rule"]
    print(f"\n  {B('Active Core Rules')} ({len(rules)} total)\n")
    for rule in sorted(rules, key=lambda x: x["risk"] != "critical"):
        cov = G(chr(10003)) if rule["covered"] else R(chr(10007))
        risk_fn = R if rule["risk"] == "critical" else Y if rule["risk"] == "high" else D
        print(f"  {cov} [{risk_fn(rule['risk'][:4])}] {rule['label'][:65]}")


def main() -> None:
    args = sys.argv[1:]
    fast = "--fast" in args

    if "--list" in args:
        list_rules()
        return

    header("Mediastack Core Rules Enforcer")
    t_start = time.time()
    failures = 0

    failures += run_tier(TIER_0, "Tier 0 — Architectural Integrity")
    if failures > 0:
        print(f"\n  {_SEP}")
        print(f"  {R(chr(10007))} Blocked on Tier 0 — fix architectural violations first")
        print(f"  {D('ms-semgrep --verify   ms-coverage --section rule')}")
        print()
        sys.exit(1)

    failures += run_tier(TIER_1, "Tier 1 — Contract & Quality")
    if not fast:
        failures += run_tier(TIER_2, "Tier 2 — Behavioral Tests")

    elapsed = time.time() - t_start
    print(f"\n  {_SEP}")
    if failures == 0:
        print(f"  {G(chr(10003))}  All Core Rules satisfied  {D(f'{elapsed:.0f}s')}")
    else:
        print(f"  {R(chr(10007))}  {failures} rule(s) violated  {D(f'{elapsed:.0f}s')}")
    print()
    sys.exit(0 if failures == 0 else 1)


if __name__ == "__main__":
    main()
