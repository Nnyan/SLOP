def check_handoff_freshness() -> tuple[bool, str]:
    """Tier 1 (S-75-C): handoff SHA freshness — warn-only.

    Thin wrapper: delegates to tools/check_handoff_freshness.py.

    Parses the SHA declared in docs/MANAGER-HANDOFF.md for origin/main and
    compares it to the live ``git rev-parse origin/main`` output (GROUND-class).

    Verdicts:
      verified      — declared SHA is a prefix of live SHA [GROUND: git rev-parse]
      DRIFT         — declared SHA does NOT match live SHA (loud warn)
      INDETERMINATE — origin unreachable or SHA line absent/unparseable (loud warn)

    Always returns True (warn-only TIER_1). Graduates to blocking when two
    consecutive batches show DRIFT without a corresponding handoff update commit.
    """
    tool = REPO / "tools" / "check_handoff_freshness.py"
    if not tool.exists():
        return True, "check_handoff_freshness.py not present (skip)"

    venv_py = REPO / ".venv" / "bin" / "python3"
    py = str(venv_py) if venv_py.exists() else "python3"

    _rc, out = _run([py, str(tool)], timeout=20)
    out = out.strip()
    if "INDETERMINATE" in out:
        return True, f"WARNING (INDETERMINATE): {out}"
    if "DRIFT" in out:
        return True, f"WARNING (DRIFT): {out}"
    return True, out


# ── fact-store freshness (S-75-D) ──────────────────────────────
def check_fact_freshness() -> tuple[bool, str]:
    """Tier 1 (S-75-D): fact-store freshness / verify-probe audit — warn-only.

    Shells out to tools/audit_fact_freshness.py which:
      - Parses memory-file YAML frontmatter for ``verify_probe`` entries and
        runs each probe (GROUND); a failing probe → DRIFT (loud warn).
      - Scans CLAUDE.md "Project facts" for ``<!-- verify: <cmd> -->``
        annotations and runs each command (GROUND); failure → DRIFT.
      - Counts facts with NO probe as UNPROBED.  UNPROBED facts are counted
        by a shrink-only ratchet (``.factprobe-baseline.json``); a growing
        UNPROBED count emits a WARNING.

    Vocabulary: GROUND = touches physics (may say verified or DRIFT).
    UNPROBED = counted, never silently blessed.
    "A green light must be able to go red against physics."

    Always returns True (warn-only TIER_1).  Promotion trigger: when DRIFT
    findings become recurrent (facts that drift for >30d without remediation).
    """
    script = REPO / "tools" / "audit_fact_freshness.py"
    if not script.exists():
        return True, "audit_fact_freshness.py not present (skip)"

    venv_py = REPO / ".venv" / "bin" / "python3"
    py = str(venv_py) if venv_py.exists() else "python3"

    _rc, out = _run([py, str(script), "--repo", str(REPO)], timeout=60)

    drift_lines = [ln for ln in out.splitlines() if ln.startswith("DRIFT:")]
    ratchet_warnings = [ln for ln in out.splitlines() if ln.startswith("WARNING:")]
    verified_lines = [ln for ln in out.splitlines() if ln.startswith("VERIFIED:")]
    unprobed_lines = [ln for ln in out.splitlines() if ln.startswith("UNPROBED:")]

    parts: list[str] = []
    if verified_lines:
        parts.append(f"{len(verified_lines)} fact(s) verified (GROUND)")
    if unprobed_lines:
        parts.append(f"{len(unprobed_lines)} fact(s) UNPROBED (counted, not blessed)")
    if drift_lines:
        parts.append(f"WARNING — {len(drift_lines)} DRIFT finding(s):")
        parts.extend(f"    {ln[:120]}" for ln in drift_lines[:5])
        if len(drift_lines) > 5:
            parts.append(f"    ... and {len(drift_lines) - 5} more")
    for w in ratchet_warnings:
        parts.append(f"WARNING — {w[:120]}")

    if not parts:
        return True, "fact-freshness: no findings"
    return True, "\n".join(parts)  # always True — warn-only


def check_probe_aging() -> tuple[bool, str]:
    """Tier 1 (BATCH-11 S1, P0): GROUND-gate brownout detector — warn-only.

    Shells out to tools/audit_probe_aging.py, which runs every probe registered
    in tools/probe_registry.json (an OPEN SEAM — see docs/PROBE-REGISTRY.md) and
    records per run whether each reached GROUND (verified/DRIFT) or browned out
    (INDETERMINATE/unparseable/missing-input/no-date/configured-host-rc127/
    wrong-target).  A probe with NO ground-touch in N consecutive runs ages to
    DRIFT — closing the "GROUND-gate brownout" class (report §4g) for all probes
    at once.

    Non-hook trigger: this is a plain TIER_1 check; it does NOT depend on S4's
    session-boundary hooks.

    Vocabulary: GROUND = touches physics (may say verified or DRIFT).
    INDETERMINATE is red-eligible after N runs.  "A green light is only
    trustworthy if it can go red against physics."

    Always returns True (warn-only TIER_1).  Does NOT auto-promote to blocking —
    promotion is a later deliberate recorded act (Enforcement-Lifecycle).
    """
    script = REPO / "tools" / "audit_probe_aging.py"
    if not script.exists():
        return True, "audit_probe_aging.py not present (skip)"

    venv_py = REPO / ".venv" / "bin" / "python3"
    py = str(venv_py) if venv_py.exists() else "python3"

    _rc, out = _run([py, str(script), "--repo", str(REPO), "--record"], timeout=120)

    drift_lines = [ln for ln in out.splitlines() if ln.startswith("DRIFT:")]
    brownout_lines = [ln for ln in out.splitlines() if ln.startswith("BROWNOUT:")]
    ground_lines = [ln for ln in out.splitlines() if ln.startswith("GROUND-TOUCH:")]
    ratchet_warnings = [ln for ln in out.splitlines() if ln.startswith("WARNING:")]

    parts: list[str] = []
    if ground_lines:
        parts.append(f"{len(ground_lines)} probe(s) touched GROUND")
    if brownout_lines:
        parts.append(f"{len(brownout_lines)} probe(s) browned out this run")
    if drift_lines:
        parts.append(f"WARNING — {len(drift_lines)} probe(s) aged to DRIFT:")
        parts.extend(f"    {ln[:120]}" for ln in drift_lines[:5])
        if len(drift_lines) > 5:
            parts.append(f"    ... and {len(drift_lines) - 5} more")
    for w in ratchet_warnings:
        parts.append(f"WARNING — {w[:120]}")

    if not parts:
        return True, "probe-aging: no findings"
    return True, "\n".join(parts)  # always True — warn-only


