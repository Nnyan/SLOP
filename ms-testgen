def _sanitize_id(node_id: str) -> str:
    """Convert a node ID to a valid Python identifier."""
    return (node_id.replace(":", "_").replace("/", "_").replace("-", "_")
                   .replace("{", "").replace("}", "").replace(".", "_")
                   .replace("*", "").strip("_"))[:60]


def gen_route_test(node: dict) -> str:
    """Generate behavioral test for an API route."""
    label   = node["label"]          # "GET /api/health/sources"
    method  = label.split()[0].lower()
    path    = label.split()[-1]
    handler = node.get("detail", "").replace("handler=", "")
    risk    = node["risk"]
    safe_id = _sanitize_id(node["id"])

    # Determine test strategy based on method and path
    body_required = method in ("post", "put", "patch")
    is_destructive = method in ("delete", "post") and any(
        w in path for w in ("reset", "remove", "delete", "approve", "reject", "install")
    )

    # Build a minimal valid body for common patterns
    body_hint = ""
    if "/maintenance-windows" in path and method == "post":
        body_hint = '{"app_key": "sonarr", "check_name": "http", "label": "Test", "day_of_week": 0, "hour_start": 2, "hour_end": 4}'
    elif "/settings" in path and method in ("put", "patch"):
        body_hint = '{"health_check_interval_secs": 60}'
    elif "/validate-secrets" in path:
        body_hint = '{"checks": []}'
    elif "/validate" in path:
        body_hint = '{"domain": "test.local", "puid": 1000, "pgid": 1000, "timezone": "UTC"}'
    elif method == "post" and body_required:
        body_hint = "{}"

    path_for_call = (path.replace("{key}", "sonarr")
                    .replace("{fix_id}", "99999")
                    .replace("{window_id}", "99999")
                    .replace("{job_id}", "test_job")
                    .replace("{source_id}", "99999")
                    .replace("{instance_key}", "test_instance")
                    .replace("{slot}", "auth")
                    .replace("{phase}", "deploy")
                    .replace("{id}", "99999")
                    .replace("{new_key}", "sonarr_v2"))
    label_esc = label.replace("{", "{{").replace("}", "}}")

    lines = [f'    def test_{safe_id}_responds(self, app_client):']
    lines.append(f'        """{label} must respond without 500.')
    lines.append(f'        Risk={risk}. handler={handler}')
    lines.append(f'        Tests: status code, response is JSON, no server error."""')
    lines.append(f'        client, _ = app_client')

    if method == "get":
        lines.append(f'        r = client.get("{path_for_call}")')
        lines.append(f'        assert r.status_code != 500, (')
        lines.append(f'            f"{label_esc} returned 500: {{r.text[:200]}}"')
        lines.append(f'        )')
        lines.append(f'        assert r.status_code in (200, 204, 404, 409, 422), (')
        lines.append(f'            f"{label_esc} unexpected status {{r.status_code}}"')
        lines.append(f'        )')
        # Schema check for 200 responses
        lines.append(f'        if r.status_code == 200:')
        lines.append(f'            body = r.json()')
        lines.append(f'            assert body is not None, "{label_esc} returned null JSON"')

    elif method in ("post", "put", "patch") and not is_destructive:
        if body_hint:
            lines.append(f'        r = client.{method}("{path_for_call}", json={body_hint})')
        else:
            lines.append(f'        r = client.{method}("{path_for_call}")')
        lines.append(f'        # Empty/minimal body should return 4xx (validated) not 500')
        lines.append(f'        assert r.status_code != 500, (')
        lines.append(f'            f"{label_esc} returned 500 on minimal body: {{r.text[:200]}}"')
        lines.append(f'        )')
        if body_required and not body_hint:
            lines.append(f'        # No body → must reject with 422, not crash with 500')
            lines.append(f'        r_empty = client.{method}("{path_for_call}")')
            lines.append(f'        assert r_empty.status_code in (200, 204, 400, 409, 422), (')
            lines.append(f'            f"Missing body should get 4xx not 500, got {{r_empty.status_code}}"')
            lines.append(f'        )')

    elif is_destructive:
        lines.append(f'        # Non-existent ID → must return 4xx not 500')
        if body_hint:
            lines.append(f'        r = client.{method}("{path_for_call}", json={body_hint})')
        else:
            lines.append(f'        r = client.{method}("{path_for_call}")')
        lines.append(f'        assert r.status_code != 500, (')
        lines.append(f'            f"{label_esc} returned 500 on non-existent resource: {{r.text[:200]}}"')
        lines.append(f'        )')
        lines.append(f'        assert r.status_code in (200, 204, 400, 404, 409, 422), (')
        lines.append(f'            f"Non-existent ID should get 4xx, got {{r.status_code}}"')
        lines.append(f'        )')
    else:
        lines.append(f'        r = client.{method}("{path_for_call}")')
        lines.append(f'        assert r.status_code != 500, f"{label_esc} must not return 500"')

    return "\n".join(lines)


def gen_table_test(node: dict) -> str:
    """Generate behavioral test for a DB table."""
    table  = node["label"]
    safe_id = _sanitize_id(node["id"])
    risk   = node["risk"]

    # Determine appropriate write+read test based on table name
    if table == "settings":
        write_sql = "INSERT OR REPLACE INTO settings (key, value) VALUES ('__test_key__', 'test_value')"
        read_sql  = "SELECT value FROM settings WHERE key='__test_key__'"
        del_sql   = "DELETE FROM settings WHERE key='__test_key__'"
        check     = "assert row is not None and row[0] == 'test_value'"
    elif table == "operations":
        write_sql = "INSERT INTO operations (subject_type, subject_key, operation, status, started_at) VALUES ('app', '__test__', 'install', 'running', unixepoch())"
        read_sql  = "SELECT status FROM operations WHERE subject_key='__test__'"
        del_sql   = "DELETE FROM operations WHERE subject_key='__test__'"
        check     = "assert row is not None and row[0] == 'running'"
    elif table == "health_checks":
        write_sql = "INSERT OR REPLACE INTO health_checks (subject_type, subject_key, check_name, status, summary, updated_at) VALUES ('app', '__test__', 'http', 'ok', 'Test', unixepoch())"
        read_sql  = "SELECT status FROM health_checks WHERE subject_key='__test__'"
        del_sql   = "DELETE FROM health_checks WHERE subject_key='__test__'"
        check     = "assert row is not None and row[0] == 'ok'"
    elif table == "pending_fixes":
        write_sql = "INSERT OR IGNORE INTO pending_fixes (app_key, check_name, action_type, problem, suggested_fix) VALUES ('__test__', 'http', 'restart', 'Test problem', 'docker restart __test__')"
        read_sql  = "SELECT action_type FROM pending_fixes WHERE app_key='__test__'"
        del_sql   = "DELETE FROM pending_fixes WHERE app_key='__test__'"
        check     = "assert row is not None and row[0] == 'restart'"
    elif table == "fix_history":
        write_sql = "INSERT INTO fix_history (app_key, error_type, context, suggested_fix, outcome, created_at) VALUES ('__test__', 'http', 'ctx', 'cmd', 'success', unixepoch())"
        read_sql  = "SELECT outcome FROM fix_history WHERE app_key='__test__'"
        del_sql   = "DELETE FROM fix_history WHERE app_key='__test__'"
        check     = "assert row is not None and row[0] == 'success'"
    else:
        # Generic: just verify table exists and is queryable
        write_sql = None
        read_sql  = f"SELECT COUNT(*) FROM {table}"
        del_sql   = None
        check     = "assert row is not None"

    lines = [f'    def test_table_{safe_id}_round_trip(self, test_db):']
    lines.append(f'        """Table \'{table}\' must support write→read→delete round-trip.')
    lines.append(f'        Risk={risk}. Verifies table exists, schema is correct, and data persists."""')
    lines.append(f'        from backend.core.state import StateDB')
    lines.append(f'        with StateDB() as db:')

    if write_sql:
        lines.append(f'            # Ensure table exists')
        if table == "pending_fixes":
            lines.append(f'            db.execute("""CREATE TABLE IF NOT EXISTS pending_fixes (')
            lines.append(f'                id INTEGER PRIMARY KEY, app_key TEXT NOT NULL,')
            lines.append(f'                check_name TEXT NOT NULL, action_type TEXT NOT NULL,')
            lines.append(f'                problem TEXT NOT NULL, suggested_fix TEXT NOT NULL,')
            lines.append(f'                confidence REAL NOT NULL DEFAULT 0.5,')
            lines.append(f'                status TEXT NOT NULL DEFAULT \'pending\', model TEXT,')
            lines.append(f'                created_at INTEGER NOT NULL DEFAULT (unixepoch()),')
            lines.append(f'                resolved_at INTEGER,')
            lines.append(f'                UNIQUE(app_key, check_name, action_type))""")')
        lines.append(f'            # Write')
        lines.append(f'            db.execute("{write_sql}")')
        lines.append(f'            # Read back')
        lines.append(f'            row = db.execute("{read_sql}").fetchone()')
        lines.append(f'            {check}, (')
        lines.append(f'                f"Write to {table} succeeded but read returned: {{row}}"')
        lines.append(f'            )')
        lines.append(f'            # Cleanup')
        lines.append(f'            db.execute("{del_sql}")')
    else:
        lines.append(f'            # Verify table is queryable')
        lines.append(f'            row = db.execute("{read_sql}").fetchone()')
        lines.append(f'            {check}, (')
        lines.append(f'                f"Table {table} query failed or returned unexpected result: {{row}}"')
        lines.append(f'            )')

    return "\n".join(lines)


def gen_provider_test(node: dict) -> str:
    """Generate behavioral test for an infra provider."""
    cls     = node["label"]
    fname   = node["notes"].replace("file=", "") if "file=" in node.get("notes","") else ""
    safe_id = _sanitize_id(node["id"])
    slot    = node["detail"].replace("slot=", "")

    # Map class name to import
    module_map = {
        "GlanceDashboardProvider": "backend.infra.providers.dashboard_glance",
        "HomepageProvider":        "backend.infra.providers.dashboard_homepage",
        "TinyauthProvider":        "backend.infra.providers.auth_tinyauth",
        "AutheliaProvider":        "backend.infra.providers.auth_authelia",
        "DockhandProvider":        "backend.infra.providers.management_alternatives",
        "DockgeProvider":          "backend.infra.providers.management_alternatives",
        "KomodoProvider":          "backend.infra.providers.management_alternatives",
        "PortainerBEProvider":     "backend.infra.providers.management_alternatives",
        "PortainerProvider":       "backend.infra.providers.management_portainer",
        "CloudflareTunnelProvider":"backend.infra.providers.tunnel_cloudflare",
        "TailscaleProvider":       "backend.infra.providers.tunnel_tailscale",
        "HeadscaleProvider":       "backend.infra.providers.tunnel_headscale",
        "GluetunProvider":         "backend.infra.providers.vpn_gluetun",
    }
    module = module_map.get(cls, f"backend.infra.providers.{slot}_{fname.replace('.py','')}")

    lines = [f'    def test_provider_{safe_id}_failure_no_exception(self, tmp_path):']
    lines.append(f'        """{cls}.deploy() failure must return ProviderResult, not raise.')
    lines.append(f'        Key regression: result.stderr on (rc, str) tuple → NameError.')
    lines.append(f'        Every provider failure path must return ProviderResult(ok=False)."""')
    lines.append(f'        from unittest.mock import patch, MagicMock')
    lines.append(f'        from {module} import {cls}')
    lines.append(f'        provider = {cls}()')
    lines.append(f'        cfg = {{"domain": "test.local", "network": "mediastack",')
    lines.append(f'               "config_root": str(tmp_path / "config")}}')
    lines.append(f'        fail_sp = MagicMock()')
    lines.append(f'        fail_sp.returncode = 1')
    lines.append(f'        fail_sp.stdout = ""')
    lines.append(f'        fail_sp.stderr = "Error: image pull failed"')
    lines.append(f'        with patch("subprocess.run", return_value=fail_sp):')
    lines.append(f'            try:')
    lines.append(f'                result = provider.deploy(cfg)')
    lines.append(f'                # Must return a result object, not raise')
    lines.append(f'                assert not result.ok, (')
    lines.append(f'                    f"{cls} returned ok=True on compose failure"')
    lines.append(f'                )')
    lines.append(f'                assert result.message or result.detail, (')
    lines.append(f'                    f"{cls} failure message is empty"')
    lines.append(f'                )')
    lines.append(f'            except NameError as e:')
    lines.append(f'                raise AssertionError(')
    lines.append(f'                    f"NameError in {cls} failure path: {{e}}. "')
    lines.append(f'                    "Bug: result.stderr called on (rc, str) tuple — "')
    lines.append(f'                    "compose_up returns a tuple not an object."')
    lines.append(f'                ) from e')

    return "\n".join(lines)


def gen_manifest_test(node: dict) -> str:
    """Generate behavioral test for an app manifest YAML."""
    key     = node["id"].replace("manifest:", "")
    label   = node["label"]
    fpath   = node["file"]
    safe_id = _sanitize_id(node["id"])

    lines = [f'    def test_manifest_{safe_id}_schema_valid(self):']
    lines.append(f'        """Manifest {key} ({label}) must have required fields and valid structure."""')
    lines.append(f'        import yaml as _yaml')
    lines.append(f'        fpath = REPO / "{fpath}"')
    lines.append(f'        assert fpath.exists(), f"Manifest file missing: {fpath}"')
    lines.append(f'        data = _yaml.safe_load(fpath.read_text())')
    lines.append(f'        assert isinstance(data, dict), "Manifest must be a YAML dict"')
    lines.append(f'        # Required fields')
    lines.append(f'        for field in ("display_name", "category", "image"):')
    lines.append(f'            assert field in data, (')
    lines.append(f'                f"Manifest {key} missing required field: {{field}}"')
    lines.append(f'            )')
    lines.append(f'        # Image must not be empty')
    lines.append(f'        assert data.get("image"), f"Manifest {key}: image is empty"')
    lines.append(f'        # Ports must be a list if present')
    lines.append(f'        if "ports" in data:')
    lines.append(f'            assert isinstance(data["ports"], list), (')
    lines.append(f'                f"Manifest {key}: ports must be a list"')
    lines.append(f'            )')
    lines.append(f'            for p in data["ports"]:')
    lines.append(f'                assert isinstance(p.get("host_port"), int), (')
    lines.append(f'                    f"Manifest {key}: port entry missing integer host_port"')
    lines.append(f'                )')
    lines.append(f'        # post_deploy steps must be valid types')
    lines.append(f'        valid_step_types = {{"wait_healthy", "api_ready", "wire", "smoke_test", "run"}}')
    lines.append(f'        for step in data.get("post_deploy", []):')
    lines.append(f'            assert step.get("type") in valid_step_types, (')
    lines.append(f'                f"Manifest {key}: unknown post_deploy step type: {{step.get(\'type\')}}"')
    lines.append(f'            )')

    return "\n".join(lines)


def gen_step_test(node: dict) -> str:
    """Generate behavioral test for a wizard step function."""
    fn_name = node["detail"]  # e.g. "step_complete"
    label   = node["label"]
    safe_id = _sanitize_id(node["id"])
    risk    = node["risk"]

    lines = [f'    def test_{safe_id}_result_has_ok_field(self, test_db, tmp_path):']
    lines.append(f'        """Wizard step {fn_name} must return StepResult with ok field.')
    lines.append(f'        Risk={risk}. Step must NEVER raise an uncaught exception — ')
    lines.append(f'        all failures must be returned as StepResult(ok=False)."""')
    lines.append(f'        from backend.platform.wizard import WizardInput, {fn_name}')
    lines.append(f'        from unittest.mock import patch, MagicMock')
    lines.append(f'        inp = WizardInput(')
    lines.append(f'            domain="step-test.local",')
    lines.append(f'            config_root=str(tmp_path / "config"),')
    lines.append(f'            media_root=str(tmp_path / "media"),')
    lines.append(f'            puid=1000, pgid=1000, timezone="UTC",')
    lines.append(f'        )')
    lines.append(f'        # Mock all external calls so step exercises pure logic')
    lines.append(f'        sp_ok = MagicMock(); sp_ok.returncode = 0; sp_ok.stdout = "ok"; sp_ok.stderr = ""')
    lines.append(f'        with patch("subprocess.run", return_value=sp_ok):')
    lines.append(f'            try:')
    lines.append(f'                result = {fn_name}(inp)')
    lines.append(f'                assert hasattr(result, "ok"), (')
    lines.append(f'                    f"{fn_name} must return StepResult with .ok field, got: {{type(result)}}"')
    lines.append(f'                )')
    lines.append(f'                assert hasattr(result, "step"), (')
    lines.append(f'                    f"{fn_name} must return StepResult with .step field"')
    lines.append(f'                )')
    lines.append(f'                # ok=False is acceptable — step may have prerequisites not met')
    lines.append(f'                # What is NOT acceptable: raising an exception')
    lines.append(f'            except SystemExit:')
    lines.append(f'                pass  # Some steps may sys.exit on critical failure')
    lines.append(f'            except Exception as _e:')
    lines.append(f'                raise AssertionError(')
    lines.append(f'                    f"{fn_name} raised {{type(_e).__name__}}: {{_e}}. "')
    lines.append(f'                    "Wizard steps must NEVER raise — return StepResult(ok=False) instead."')
    lines.append(f'                ) from _e')

    return "\n".join(lines)


def gen_tool_test(node: dict) -> str:
    """Generate behavioral test for operational tools."""
    tool    = node["label"]
    safe_id = _sanitize_id(node["id"])

    tool_file = node['file']
    lines = [f'    def test_tool_{safe_id}_runs_without_error(self):']
    lines.append(f'        """Tool {tool} must run without crashing (exit 0 or non-5x)."""')
    lines.append(f'        import subprocess, sys')
    lines.append(f'        tool_path = REPO / "{tool_file}"')
    lines.append(f'        if not tool_path.exists():')
    lines.append(f'            pytest.skip("Tool {tool} not found")')
    if tool.endswith('.py'):
        lines.append(f'        r = subprocess.run(')
        lines.append(f'            [sys.executable, str(tool_path), "--help"],')
        lines.append(f'            capture_output=True, text=True, timeout=30, cwd=str(REPO),')
        lines.append(f'        )')
    else:
        lines.append(f'        r = subprocess.run(')
        lines.append(f'            ["bash", "-n", str(tool_path)],')
        lines.append(f'            capture_output=True, text=True, timeout=10,')
        lines.append(f'        )')
    lines.append(f'        assert r.returncode in (0, 1, 2), (')
    lines.append(f'            f"Tool {tool} exited with code {{r.returncode}}. stderr: {{r.stderr[:200]}}"')
    lines.append(f'        )')

    return "\n".join(lines)


