#!/usr/bin/env python3
"""ms-testgen — Mediastack Test Generation Engine

Reads the coverage map from ms-coverage and auto-generates behavioral tests
for every uncovered or under-tested node. Uses templates calibrated per node
kind (route, table, provider, manifest, step, view, tool).

Output: tests/test_generated_behavioral.py  (auto-maintained, never hand-edit)

Usage:
  ms-testgen                # generate tests for all gaps
  ms-testgen --dry-run      # print what would be generated without writing
  ms-testgen --section X    # only generate for kind=X (route/table/provider/etc.)
  ms-testgen --verify       # run generated tests and report results
  ms-testgen --force        # regenerate even for already-covered nodes

Install: sudo ln -sf /srv/mediastack/ms-testgen /usr/local/bin/ms-testgen
"""
from __future__ import annotations

import ast
import json
import subprocess
import sys
import textwrap
import time
