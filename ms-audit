def run_pytest(markers: list[str] | None = None,
               test_file: str | None = None) -> dict[str, Any]:
    """Run pytest and return structured results."""
    target = test_file or str(AUDIT_TEST.resolve())
    # Use venv python if available (has all test dependencies)
    venv_py = REPO / ".venv" / "bin" / "python3"
    py = str(venv_py) if venv_py.exists() else sys.executable
    cmd = [py, "-m", "pytest", target,
           "-v", "--tb=short", "--no-header",
           f"--rootdir={REPO}"]
    if markers:
        cmd.extend(["-k", " or ".join(markers)])

    t0 = time.time()
    env = dict(os.environ)
    env["PYTHONPATH"] = str(REPO)
    result = subprocess.run(cmd, capture_output=True, text=True, cwd=REPO, env=env)
    elapsed = time.time() - t0

    passed = failed = errors = 0
    failures: list[dict] = []

    # Parse the summary line (reliable across pytest versions and color settings)
    # e.g. "72 passed, 1 warning in 6.73s" or "5 failed, 67 passed in 4.8s"
    for line in result.stdout.splitlines():
        m_pass = re.search(r"(\d+) passed", line)
        m_fail = re.search(r"(\d+) failed", line)
        m_err  = re.search(r"(\d+) error", line)
        if m_pass: passed = int(m_pass.group(1))
        if m_fail: failed = int(m_fail.group(1))
        if m_err:  errors = int(m_err.group(1))
        # Collect failure names from individual FAILED lines as secondary source
        if " FAILED" in line and "::" in line:
            name = line.split("::")[1].split(" ")[0]
            if name not in [f["name"] for f in failures]:
                failures.append({"name": name, "output": ""})

    # Show pytest output when 0 tests (collection failed)
    if passed == 0 and failed == 0:
        combined = (result.stdout + result.stderr).strip()
        if combined:
            print(f"\n  {YELLOW('⚠ pytest collected 0 tests — output:')} (returncode={result.returncode})")
            for line in combined.splitlines()[-15:]:
                print(f"    {DIM(line)}")

    # If 0 tests collected, pytest likely had a collection error — surface it
    if passed == 0 and failed == 0 and not args.quiet if "args" in dir() else True:
        combined = (result.stdout + result.stderr)[-3000:]
        if "no tests ran" in combined or "collected 0" in combined or result.returncode == 5:
            print(f"\n  {YELLOW('⚠ pytest collected 0 tests — showing output:')}")
            for line in combined.splitlines()[-20:]:
                print(f"    {DIM(line)}")

    return {
        "passed": passed,
        "failed": failed,
        "errors": errors,
        "elapsed": round(elapsed, 1),
        "failures": failures,
        "stdout": result.stdout[-8000:],
        "returncode": result.returncode,
        "stderr": result.stderr[-2000:],
    }


