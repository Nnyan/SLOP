        f"**Date:** {datetime.datetime.now().strftime('%Y-%m-%d %H:%M')}  ",
        ("**Result:** ✓ PASSED  " if results["failed"] == 0
         else f"**Result:** ✗ {results['failed']} FAILED  "),
        f"**Tests:** {results['passed']} passed, {results['failed']} failed  ",
        f"**Duration:** {results['elapsed']}s  ",
        f"",
        f"## Codebase Snapshot",
        f"",
        f"| Metric | Count |",
        f"|---|---|",
        f"| API Routes | {len(snap['routes'])} |",
        f"| Vue API Calls | {len(snap['vue_calls'])} |",
        f"| Catalog Apps | {len(snap['manifests'])} |",
        f"| DB Tables | {len(snap['db_tables'])} |",
        f"| Wizard Steps | {len(snap['wizard_steps'])} |",
        f"| Infra Providers | {sum(len(v) for v in snap['infra_providers'].values())} |",
        f"",
    ]

    if changes:
        lines += [f"## Changes Since Last Audit", f""]
        for k, v in changes.items():
            lines += [f"**{k}:** {', '.join(str(x) for x in v[:5])}", f""]

    if gaps:
        lines += [f"## Gaps Found ({len(gaps)})", f""]
        by_type: dict[str, list] = {}
        for g in gaps:
            by_type.setdefault(g["type"], []).append(g)
        for gtype, items in by_type.items():
            lines += [f"### {gtype.replace('_', ' ').title()} ({len(items)})", f""]
            for item in items[:10]:
                lines += [f"- **{item['item']}**", f"  - {item['suggestion']}", f""]

    if results.get("failures"):
        lines += [f"## Failed Tests", f""]
        for f in results["failures"]:
            lines += [f"- `{f['name']}`", f""]

    lines += [f"## Test Output", f"", f"```", results.get("stdout", "")[-3000:], f"```"]

    out.write_text("\n".join(lines))
    return out


# ═══════════════════════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════════════════════

def main() -> int:
    import argparse

    p = argparse.ArgumentParser(
        description="Mediastack Full Contract Audit — self-improving end-to-end test suite",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__.split("Usage:")[1].split("\n\nSelf")[0],
    )
    p.add_argument("--static",  action="store_true", help="Static analysis only")
    p.add_argument("--live",    action="store_true", help="Live API tests only")
    p.add_argument("--improve", action="store_true", help="AI gap analysis + test generation")
    p.add_argument("--apply",   action="store_true", help="Apply AI-generated tests immediately")
    p.add_argument("--report",  action="store_true", help="Save markdown report")
    p.add_argument("--summary", action="store_true", help="Show history summary")
    p.add_argument("--diff",    action="store_true", help="Only test changed areas")
    p.add_argument("--watch",   action="store_true", help="Re-run on file changes")
    p.add_argument("--model",    default="sonnet",
                   choices=["opus", "sonnet", "haiku"],
                   help="Claude model for --improve (default: sonnet)")
    p.add_argument("--provider", default="auto",
                   choices=["auto", "ollama", "groq", "awan", "claude", "openai"],
                   help="AI provider for --improve (default: auto-detect)")
    p.add_argument("--quiet",   action="store_true", help="Minimal output")
    p.add_argument("--context", default="",
                   help="Path to context file from ms-mutmut or ms-schemathesis for targeted LLM test generation")
    args = p.parse_args()

    if args.summary:
        show_summary()
        return 0

    # ── Fingerprint codebase ────────────────────────────────────────────────
    print(f"\n{BOLD('Mediastack Full Contract Audit')}")
    print(f"{DIM('─' * 60)}")

    print(f"\n  {CYAN('→')} Scanning codebase…", end=" ", flush=True)
    snap = fingerprint()
    n_routes = len(snap["routes"])
    n_apps   = len(snap["manifests"])
    n_tables = len(snap["db_tables"])
    _parts = []
    if SNAP_FILE.exists():
        try:
            _old = json.loads(SNAP_FILE.read_text())
            _or = len(_old.get("routes",    []))
            _oa = len(_old.get("manifests", []))
            _parts.append(f"{_or} \u2192 {n_routes} routes" if _or != n_routes else f"{n_routes} routes")
            _parts.append(f"{_oa} \u2192 {n_apps} apps"    if _oa != n_apps   else f"{n_apps} apps")
        except Exception:
            _parts = [f"{n_routes} routes", f"{n_apps} apps"]
    else:
        _parts = [f"{n_routes} routes", f"{n_apps} apps"]
    _parts.append(f"{n_tables} tables")
    print(f"done  {DIM(' \u00b7 '.join(_parts))}")

    # Load previous snapshot and compute diff
    changes: dict[str, list[str]] = {}
    if SNAP_FILE.exists():
        try:
            old_snap = json.loads(SNAP_FILE.read_text())
            changes = diff_snapshots(old_snap, snap)
            if changes and not args.quiet:
                total_changes = sum(len(v) for v in changes.values())
                print(f"  {CYAN('→')} {total_changes} change(s) since last audit: "
                      f"{DIM(', '.join(f'{k}({len(v)})' for k,v in list(changes.items())[:4]))}")
        except Exception:
            pass

    # ── Gap analysis ────────────────────────────────────────────────────────
    print(f"  {CYAN('→')} Analyzing gaps…", end=" ", flush=True)
    gaps = find_gaps(snap, changes)
    if gaps:
        print(f"{YELLOW(f'{len(gaps)} gap(s) found')}")
        if not args.quiet:
            for g in gaps[:5]:
                print(f"    {DIM('•')} [{g['type']}] {g['item'][:65]}")
            if len(gaps) > 5:
                print(f"    {DIM(f'... and {len(gaps)-5} more')}")
    else:
        print(f"{GREEN('none')}")

    # ── Select test markers based on mode ──────────────────────────────────
    markers = None
    if args.diff and changes:
        # Only run test classes related to changed areas
        marker_map = {
            "routes_added":     ["TestAPIContracts", "TestFrontendBackendContracts"],
            "manifests_added":  ["TestManifestIntegrity"],
            "db_tables_added":  ["TestDataLayer"],
            "wizard_steps_added": ["TestConfiguration", "TestWorkflowStateMachines"],
            "providers_added":  ["TestLLMIntegration", "TestDataSharingContracts"],
            "vue_calls_added":  ["TestFrontendBackendContracts", "TestResponseSchema"],
        }
        active = set()
        for change_key in changes:
            active.update(marker_map.get(change_key, []))
        if active:
            markers = list(active)
            print(f"  {CYAN('→')} Running targeted tests: {', '.join(markers)}")

    # ── Run tests ───────────────────────────────────────────────────────────
    print(f"\n  {CYAN('→')} Running audit tests…")
    t0 = time.time()
    results = run_pytest(markers=markers)
    elapsed = time.time() - t0

    # Print results
    print()
    status_line = (
        f"  {GREEN('✓ PASSED')} — {results['passed']} tests in {elapsed:.1f}s"
        if results["failed"] == 0
        else f"  {RED(f'✗ FAILED')} — {results['passed']} passed, {results['failed']} failed in {elapsed:.1f}s"
    )
    print(status_line)

    if results["failures"] and not args.quiet:
        print()
        for f in results["failures"][:5]:
            print(f"    {RED('✗')} {f['name']}")

    # Print test output on failure
    if results["failed"] > 0:
        print(f"\n{DIM('─' * 60)}")
        # Show just the FAILED sections from stdout
        in_fail = False
        for line in results["stdout"].splitlines():
            if "FAILED" in line or "short test summary" in line:
                in_fail = True
            if in_fail:
                print(f"  {line}")
        print(f"{DIM('─' * 60)}")

    # ── AI improvement ──────────────────────────────────────────────────────
    if args.improve:
        # Auto-assemble context from: explicit --context flag + recent tool outputs + Core Rules
        _extra_context = _assemble_improve_context(
            explicit_file=args.context,
            include_core_rules=True,
        )
        improve_with_ai(gaps, changes, model=args.model, apply=args.apply,
                        extra_context=_extra_context)
        # Provider can also be set via MS_AUDIT_PROVIDER env var

    # ── Save snapshot — only update baseline when gaps are closed ──────────
    # Preserving the old snapshot when gaps exist means next run re-reports
    # them until tests are written, rather than silently forgetting them.
    if not gaps:
        SNAP_FILE.write_text(json.dumps(snap, indent=2))
    elif args.improve:
        SNAP_FILE.write_text(json.dumps(snap, indent=2))
    else:
        if not args.quiet:
            print(f"  {YELLOW('!')} Snapshot not updated — {len(gaps)} gap(s) remain open")
            print(f"    Run {DIM('ms-audit --improve')} to generate tests, or add manually then re-run")

    # ── Save report ─────────────────────────────────────────────────────────
    if args.report:
        report_path = save_report(results, gaps, changes, snap)
        print(f"\n  {GREEN('✓')} Report: {report_path}")

    # ── Save history ─────────────────────────────────────────────────────────
    _save_history({
        "timestamp": datetime.datetime.now(datetime.timezone.utc).isoformat(),
        "passed":    results["passed"],
        "failed":    results["failed"],
        "elapsed":   round(elapsed, 1),
        "gaps_found": len(gaps),
        "gaps":      gaps[:10],
        "changes":   {k: v[:5] for k, v in changes.items()},
        "snapshot":  {k: len(v) if isinstance(v, list)
                      else sum(len(x) for x in v.values()) if isinstance(v, dict)
                      else v
                      for k, v in snap.items() if k != "ts"},
    })

    # ── Recommendations ─────────────────────────────────────────────────────
    if gaps and not args.improve and not args.quiet:
        print(f"\n  {DIM('Tip:')} run {CYAN('ms-audit --improve')} to generate tests for {len(gaps)} gaps")
        # Check what providers are available
        _has_ollama = False
        try:
            import urllib.request as _u
            _u.urlopen("http://localhost:11434/api/tags", timeout=1)
            _has_ollama = True
        except Exception:
            pass
        if _has_ollama:
            print(f"       {GREEN('Ollama is running')} — ms-audit will use it automatically (free, no account needed)")
        elif any(os.environ.get(k) for k in ["GROQ_API_KEY","AWAN_API_KEY","ANTHROPIC_API_KEY","OPENAI_API_KEY"]):
            print(f"       API key detected — run ms-audit --improve to generate tests")
        else:
            print(f"       Free options: start Ollama, or export GROQ_API_KEY (free at console.groq.com)")

    print()
    return 0 if results["failed"] == 0 else 1


if __name__ == "__main__":
    sys.exit(main())