def fingerprint() -> dict[str, Any]:
    """
    Snapshot the entire codebase structure. Run before and after changes
    to identify what's new and needs test coverage.
    """
    snap: dict[str, Any] = {
        "ts": time.time(),
        "routes": [],
        "vue_calls": [],
        "manifests": [],
        "db_tables": [],
        "wizard_steps": [],
        "action_types": [],
        "context_sources": [],
        "infra_providers": {},
        "settings_keys": [],
    }

    # API routes
    for mod, pfx in PREFIXES.items():
        f = REPO / f"backend/api/{mod}.py"
        if not f.exists():
            continue
        for m in re.finditer(
            r'@router\.(get|post|put|delete|patch)\(\s*["\']([^"\']+)["\']',
            f.read_text()
        ):
            snap["routes"].append(f"{m.group(1).upper()} {pfx}{m.group(2)}")

    # Vue API calls
    for f in (REPO / "frontend" / "src").rglob("*.vue"):
        src = f.read_text()
        for m in re.finditer(r"fetch\([`'\"](/api/[^`'\"?\s{]+)", src):
            path = re.sub(r"\$\{[^}]+\}", "{id}", m.group(1))
            snap["vue_calls"].append(f"{path} [{f.name}]")

    # Catalog manifests
    for f in (REPO / "catalog" / "apps").glob("*.yaml"):
        snap["manifests"].append(f.stem)

    # DB tables
    schema = (REPO / "backend" / "core" / "schema.sql").read_text()
    snap["db_tables"] = re.findall(r"CREATE TABLE IF NOT EXISTS (\w+)", schema)

    # Wizard steps
    wizard_src = (REPO / "backend" / "platform" / "wizard.py").read_text()
    m = re.search(r"STEPS = \[(.*?)\]", wizard_src, re.DOTALL)
    if m:
        snap["wizard_steps"] = [
            re.search(r'"(\w+)"', line).group(1)
            for line in m.group(1).splitlines()
            if re.search(r'"(\w+)"', line)
        ]

    # LLM action types
    checker_src = (REPO / "backend" / "health" / "checker.py").read_text()
    map_m = re.search(r"_action_map = \{(.*?)\}", checker_src, re.DOTALL)
    if map_m:
        snap["action_types"] = list(set(
            re.findall(r'"(\w+)":\s*"(\w+)"', map_m.group(1))
        ))

    # Context assembler sources
    asm_src = (REPO / "backend" / "health" / "context_assembler.py").read_text()
    snap["context_sources"] = re.findall(r"# ── (\d+)\.", asm_src)

    # Infra providers
    for f in (REPO / "backend" / "infra" / "providers").glob("*.py"):
        src = f.read_text()
        slot_m = re.search(r'\bslot\s*=\s*["\'](\w+)["\']', src)
        if slot_m:
            keys = re.findall(r'\bkey\s*=\s*["\'](\w+)["\']', src)
            slot = slot_m.group(1)
            snap["infra_providers"].setdefault(slot, []).extend(keys)

    # Settings keys written by wizard
    snap["settings_keys"] = re.findall(
        r'set_setting\(["\'](\w+)["\']',
        (REPO / "backend" / "platform" / "wizard.py").read_text()
    )

    return snap


def diff_snapshots(old: dict, new: dict) -> dict[str, list[str]]:
    """Return what's new in `new` compared to `old`."""
    changes: dict[str, list[str]] = {}

    for key in ("routes", "vue_calls", "manifests", "db_tables",
                "wizard_steps", "settings_keys", "context_sources"):
        added = [x for x in new.get(key, []) if x not in old.get(key, [])]
        removed = [x for x in old.get(key, []) if x not in new.get(key, [])]
        if added:
            changes[f"{key}_added"] = added
        if removed:
            changes[f"{key}_removed"] = removed

    # Infra providers
    for slot, keys in new.get("infra_providers", {}).items():
        old_keys = old.get("infra_providers", {}).get(slot, [])
        new_keys = [k for k in keys if k not in old_keys]
        if new_keys:
            changes.setdefault("providers_added", []).extend(
                [f"{slot}/{k}" for k in new_keys]
            )

    return changes


