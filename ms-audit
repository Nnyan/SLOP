def find_gaps(snap: dict, changes: dict) -> list[dict[str, str]]:
    """
    Identify things in the codebase with no corresponding test coverage
    in test_comprehensive_contracts.py.
    """
    audit_src = AUDIT_TEST.read_text()
    gaps: list[dict[str, str]] = []

    # New routes not mentioned in audit
    for route in changes.get("routes_added", []):
        path = route.split(" ", 1)[-1] if " " in route else route
        segments = [s for s in path.split("/") if s and not s.startswith("{")]
        search_terms = []
        if segments:
            search_terms.append(segments[-1])
            if len(segments) >= 2:
                search_terms.append(segments[-2] + "_" + segments[-1])
            if "-" in segments[-1]:
                search_terms.extend(segments[-1].split("-"))
        covered = any(term in audit_src for term in search_terms if len(term) > 4)
        if not covered:
            gaps.append({
                "type": "new_route",
                "item": route,
                "suggestion": f"Add test verifying {route} returns correct shape and errors gracefully",
            })

    # New manifests not in manifest integrity tests
    for mfst in changes.get("manifests_added", []):
        if mfst not in audit_src:
            gaps.append({
                "type": "new_manifest",
                "item": mfst,
                "suggestion": f"Verify {mfst}.yaml loads, has valid ports, health checks work",
            })

    # New wizard steps not tested
    for step in changes.get("wizard_steps_added", []):
        if step not in audit_src:
            gaps.append({
                "type": "new_wizard_step",
                "item": step,
                "suggestion": f"Verify step_{step} is in STEPS list and dependencies are satisfied",
            })

    # New infra providers not in contracts
    for prov in changes.get("providers_added", []):
        slot, key = prov.split("/")
        if key not in audit_src:
            gaps.append({
                "type": "new_infra_provider",
                "item": prov,
                "suggestion": (
                    f"Verify {slot}/{key} provider: deploys correctly, "
                    f"calls upsert_app(tier=0), appears in health cycle"
                ),
            })

    # New DB tables not in schema tests
    for tbl in changes.get("db_tables_added", []):
        if tbl not in audit_src:
            gaps.append({
                "type": "new_db_table",
                "item": tbl,
                "suggestion": f"Add {tbl} to required tables list and verify it's created on init",
            })

    # Context sources — verify count is up to date
    # The test uses re.findall(r"# ── (\d+)\.", src) to find all source numbers
    src_count = len(snap.get("context_sources", []))
    # The test now dynamically finds max_source, so this gap only fires if
    # test_all_sources_0_through_20_present itself is missing
    # Check both comprehensive and LLM contract test files
    all_test_src = audit_src
    llm_test = REPO / "tests" / "test_llm_agent_contracts.py"
    if llm_test.exists():
        all_test_src += llm_test.read_text()
    if "test_all_sources_0_through_20_present" not in all_test_src:
        gaps.append({
            "type": "context_sources_unchecked",
            "item": f"Context source completeness test missing",
            "suggestion": "Add test_all_sources_0_through_20_present to TestContextCompleteness",
        })

    # Static analysis: endpoints without try/except
    for mod in PREFIXES:
        f = REPO / f"backend/api/{mod}.py"
        if not f.exists():
            continue
        src = f.read_text()
        for fn_m in re.finditer(
            r'@router\.(post|put|delete|patch).*?\nasync def (\w+)\(.*?(?=\n@router|\nclass |\Z)',
            src, re.DOTALL
        ):
            fn_body = fn_m.group(0)
            fn_name = fn_m.group(2)
            if "except" not in fn_body and len(fn_body) > 200:
                test_name = f"test_{mod}_{fn_name}_error_handling"
                if test_name not in audit_src:
                    gaps.append({
                        "type": "missing_error_handling",
                        "item": f"{mod}.{fn_name}",
                        "suggestion": (
                            f"POST/PUT/DELETE endpoint {fn_name} in {mod}.py has no "
                            f"exception handling — add test verifying it returns 4xx not 500 on bad input"
                        ),
                    })

    return gaps


