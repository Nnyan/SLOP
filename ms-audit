def _assemble_improve_context(
    explicit_file: str = "",
    include_core_rules: bool = True,
    max_age_hours: int = 24,
) -> str:
    """Assemble full context for the LLM from all available sources.

    Sources (auto-ingested if recent):
      1. Core Rules — architectural invariants the LLM must respect
      2. ms-mutmut survivors — mutants the tests didn't kill
      3. ms-schemathesis failures — API inputs that returned 500
      4. ms-keploy replay failures — recorded sessions that broke
      5. --context explicit file (from CLI)

    This is the single assembly point so every LLM call gets the same
    authoritative context regardless of which tool triggered it.
    """
    parts: list[str] = []
    cutoff = time.time() - (max_age_hours * 3600)

    # ── 1. Core Rules ─────────────────────────────────────────────────────
    if include_core_rules:
        core_rules_path = REPO / "docs" / "CORE_RULES.md"
        if core_rules_path.exists():
            rules_text = core_rules_path.read_text()
            # Extract just the verifiable rules (Sections 1-5), skip appendix
            # Keep it under 3000 chars to not dominate the prompt
            rules_summary = []
            for line in rules_text.splitlines():
                if line.startswith("## Section") or line.startswith("### "):
                    rules_summary.append(line)
                elif line.startswith("**") and "**" in line[2:]:
                    rules_summary.append(line)
                if len("\n".join(rules_summary)) > 2500:
                    break
            parts.append(
                "## Mediastack Core Development Rules (MUST follow)\n"
                + "\n".join(rules_summary[:60])
                + "\n\nKey rules for test generation:\n"
                + "- Rule 2.2: Test correctness not presence (execute real code, assert outcomes)\n"
                + "- Rule 2.5: Every bug fix needs a regression test\n"
                + "- Rule 3.7: Zero-data state must not return 500\n"
                + "- Rule 3.8: Security — sanitize all user-supplied identifiers\n"
                + "- Rule 4.4: Multi-table writes must be atomic (single StateDB context)\n"
            )

    # ── 2. mutmut survivors ───────────────────────────────────────────────
    survivors_file = REPO / "data" / "mutmut_survivors.json"
    if survivors_file.exists() and survivors_file.stat().st_mtime > cutoff:
        try:
            data = json.loads(survivors_file.read_text())
            survivors = data.get("survivors", [])
            if survivors:
                lines = ["## Mutation Testing — Surviving Mutants",
                         "These code mutations were NOT caught by existing tests.",
                         "Generate tests that kill each mutant (assert on the specific value).", ""]
                for s in survivors[:5]:
                    lines.append(f"Module: {s['module']} — kill rate {s['kill_rate']}%")
                    for sv in s.get("survivors", [])[:3]:
                        lines.append(f"  Survivor: {sv[:120]}")
                parts.append("\n".join(lines))
        except Exception:
            pass

    # ── 3. Schemathesis failures ──────────────────────────────────────────
    schema_file = REPO / "data" / "schemathesis_report.json"
    if schema_file.exists() and schema_file.stat().st_mtime > cutoff:
        try:
            data = json.loads(schema_file.read_text())
            server_errors = data.get("server_errors", [])
            if server_errors:
                lines = ["## API Fuzzing — Endpoints Returning 500",
                         "Rule 3.7: These endpoints returned 500 on edge-case inputs.",
                         "Generate tests that reproduce each failure.", ""]
                for err in server_errors[:8]:
                    lines.append(f"  {err.get('method','?')} {err.get('path','?')}: {err.get('detail','?')[:100]}")
                parts.append("\n".join(lines))
        except Exception:
            pass

    # ── 4. Keploy replay failures ─────────────────────────────────────────────
    keploy_report = REPO / "data" / "keploy_replay_report.json"
    if keploy_report.exists() and keploy_report.stat().st_mtime > cutoff:
        try:
            data = json.loads(keploy_report.read_text())
            findings = data.get("findings", [])
            if findings:
                lines = ["## Keploy — Replayed Sessions That Failed",
                         "These real user flows now produce different responses.",
                         "Generate regression tests that pin the correct status.", ""]
                for f in findings[:8]:
                    lines.append(f"  {f.get('method','?')} {f.get('path','?')}: "
                                 f"expected {f.get('expected_status','?')} "
                                 f"got {f.get('actual_status','error')}")
                parts.append("\n".join(lines))
        except Exception:
            pass

    # ── 5. Semgrep architectural violations ─────────────────────────────
    semgrep_file = REPO / "data" / "semgrep_findings.json"
    if semgrep_file.exists() and semgrep_file.stat().st_mtime > cutoff:
        try:
            data = json.loads(semgrep_file.read_text())
            errors = [f for f in data.get("findings", []) if f.get("severity") == "ERROR"]
            if errors:
                lines = ["## Semgrep — Architectural Rule Violations (MUST FIX)",
                         "These violations break Core Rules. Generate tests that detect them.", ""]
                for e in errors[:8]:
                    lines.append(f"  [{e['severity']}] {e['file']}:{e['line']}"
                                 f" Rule {e.get('core_rule','?')}: {e['message'][:100]}")
                parts.append("\n".join(lines))
        except Exception:
            pass

    # ── 6. Bandit security findings ───────────────────────────────────────
    bandit_file = REPO / "data" / "bandit_findings.json"
    if bandit_file.exists() and bandit_file.stat().st_mtime > cutoff:
        try:
            data = json.loads(bandit_file.read_text())
            high = [f for f in data.get("findings", []) if f.get("severity") in ("HIGH", "CRITICAL")]
            if high:
                lines = ["## Bandit — Python Security Issues",
                         "Core Rule 3.8: Generate security regression tests.", ""]
                for h in high[:6]:
                    lines.append(f"  {h.get('file','')}:{h.get('line_number','')} "
                                 f"[{h.get('test_id','')}] {h.get('issue_text','')[:100]}")
                parts.append("\n".join(lines))
        except Exception:
            pass

    # ── 7. Trivy CVE findings ─────────────────────────────────────────────
    trivy_file = REPO / "data" / "trivy_findings.json"
    if trivy_file.exists() and trivy_file.stat().st_mtime > cutoff:
        try:
            data = json.loads(trivy_file.read_text())
            crits = [f for f in data.get("findings", []) if f.get("severity") == "CRITICAL"]
            if crits:
                lines = ["## Trivy — Critical CVEs in Dependencies",
                         "Generate tests verifying vulnerable code paths are not reachable.", ""]
                for c in crits[:5]:
                    lines.append(f"  {c.get('package','')} {c.get('cve','')}: {c.get('title','')[:80]}")
                parts.append("\n".join(lines))
        except Exception:
            pass

    # ── 8. Ruff findings ──────────────────────────────────────────────────
    ruff_file = REPO / "data" / "ruff_findings.json"
    if ruff_file.exists() and ruff_file.stat().st_mtime > cutoff:
        try:
            data = json.loads(ruff_file.read_text())
            errors = data.get("findings", [])
            if errors:
                lines = ["## Ruff — Python Static Analysis (real bugs, not style)",
                         "Focus: F-prefix (undefined names), B-prefix (bugbear), S-prefix (security).", ""]
                for e in errors[:8]:
                    lines.append(f"  {e.get('filename','')}:{e.get('location',{}).get('row','')} "
                                 f"[{e.get('code','')}] {e.get('message','')[:100]}")
                parts.append("\n".join(lines))
        except Exception:
            pass

    # ── 9. ESLint Vue findings ────────────────────────────────────────────
    eslint_file = REPO / "data" / "eslint_findings.json"
    if eslint_file.exists() and eslint_file.stat().st_mtime > cutoff:
        try:
            data = json.loads(eslint_file.read_text())
            errors = [f for f in data.get("findings", []) if f.get("severity") == 2]
            if errors:
                lines = ["## ESLint — Vue Frontend Errors",
                         "Generate Playwright tests that verify these Vue behaviors are correct.", ""]
                for e in errors[:6]:
                    lines.append(f"  {e.get('file','')}:{e.get('line','')} "
                                 f"[{e.get('ruleId','')}] {e.get('message','')[:100]}")
                parts.append("\n".join(lines))
        except Exception:
            pass

    # ── 10. Hypothesis failures ────────────────────────────────────────────
    hypo_file = REPO / "data" / "hypothesis_failures.json"
    if hypo_file.exists() and hypo_file.stat().st_mtime > cutoff:
        try:
            data = json.loads(hypo_file.read_text())
            failures = data.get("findings", [])
            if failures:
                lines = ["## Hypothesis — Property Violations",
                         "These inputs violated property-based test invariants.", ""]
                for f in failures[:5]:
                    lines.append(f"  {f.get('test','')} failed on: {f.get('input','')[:100]}")
                parts.append("\n".join(lines))
        except Exception:
            pass

    # ── 11. Explicit --context file ───────────────────────────────────────
    if explicit_file and pathlib.Path(explicit_file).exists():
        try:
            content = pathlib.Path(explicit_file).read_text()
            parts.append(f"## Explicit Context\n{content[:3000]}")
        except Exception:
            pass

    if not parts:
        return ""

    return "\n\n" + "\n\n---\n\n".join(parts)

