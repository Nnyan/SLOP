# Find the repo root by searching known paths and looking for a marker file.
# This works regardless of whether ms-audit is run directly, via symlink,
# as 'python3 ms-audit', or as '/usr/local/bin/ms-audit'.
def _find_repo() -> pathlib.Path:
    # 1. Try resolving __file__ via os.readlink (most reliable for symlinks)
    try:
        _f = pathlib.Path(__file__)
        if _f.is_symlink():
            _target = pathlib.Path(os.readlink(str(_f)))
            if not _target.is_absolute():
                _target = _f.parent / _target
            return _target.resolve().parent
    except Exception:
        pass
    # 2. Try os.path.realpath
    try:
        _rp = pathlib.Path(os.path.realpath(__file__)).parent
        if (_rp / "backend" / "core" / "schema.sql").exists():
            return _rp
    except Exception:
        pass
    # 3. Search known install paths
    for _candidate in [
        pathlib.Path("/srv/mediastack"),
        pathlib.Path.home() / "mediastack",
        pathlib.Path(__file__).parent,
    ]:
        if (_candidate / "backend" / "core" / "schema.sql").exists():
            return _candidate
    # 4. Search parent directories of __file__
    for _parent in pathlib.Path(__file__).resolve().parents:
        if (_parent / "backend" / "core" / "schema.sql").exists():
            return _parent
    raise RuntimeError(
        "Cannot find Mediastack repo. Set MS_REPO env var or run from the repo directory."
    )

REPO = pathlib.Path(os.environ.get("MS_REPO", "")) if os.environ.get("MS_REPO") else _find_repo()
